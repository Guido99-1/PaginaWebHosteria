---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFloat from "../components/WhatsAppFloat.astro";
import { SITE } from "../config/site";
import "../styles/global.css";

import Testimonials from "../components/Testimonials.astro";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: "es" | "en";
};

const {
  title = SITE.name,
  description = SITE.description,
  ogImage = SITE.ogImage,
  lang = "es",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.url).toString();

// OG image: asegurar URL absoluta
const ogImageAbsolute = ogImage?.startsWith("http")
  ? ogImage
  : new URL(ogImage ?? SITE.ogImage, SITE.url).toString();

// ── Hreflang: mapeo ES ↔ EN de rutas conocidas ──────────────────────────
const esToEn: Record<string, string> = {
  es: "en",
  paquetes: "packages",
  instalaciones: "facilities",
  promociones: "promotions",
  contacto: "contact",
  // paquetes
  aventura: "adventure",
  "selva-amazonica": "amazon-rainforest",
  "banos-selva": "banos-amazon",
  "banos-extremo": "banos-extreme",
  romantico: "romantic",
  hospedaje: "lodging",
  // instalaciones
  areaHumeda: "areaHumedaEN",
  areasVerdes: "areaVerdeEn",
  discoteca: "discotecaEN",
  restaurante: "restauranteEN",
  salonDeJuegos: "salonDeJuegosEN",
  salonesEventos: "salonesEventosEN",
  // promociones
  "fin-de-semana": "weekend",
  temporada: "season",
};
const enToEs: Record<string, string> = Object.fromEntries(
  Object.entries(esToEn).map(([k, v]) => [v, k])
);

function translatePath(path: string, map: Record<string, string>) {
  const segs = path.split("/").filter(Boolean);
  return "/" + segs.map((s) => map[s] ?? s).join("/") + "/";
}

const pathname = Astro.url.pathname;
let esPath: string;
let enPath: string;

if (pathname.startsWith("/es")) {
  esPath = pathname.endsWith("/") ? pathname : pathname + "/";
  enPath = translatePath(pathname, esToEn);
} else if (pathname.startsWith("/en")) {
  enPath = pathname.endsWith("/") ? pathname : pathname + "/";
  esPath = translatePath(pathname, enToEs);
} else {
  esPath = "/es/";
  enPath = "/en/";
}

const hrefEs = new URL(esPath, SITE.url).toString();
const hrefEn = new URL(enPath, SITE.url).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b1220" />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang: ES ↔ EN -->
    <link rel="alternate" hreflang="es"        href={hrefEs} />
    <link rel="alternate" hreflang="en"        href={hrefEn} />
    <link rel="alternate" hreflang="x-default" href={hrefEs} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32"  href="/favicon-32x32.png?v=2" />
    <link rel="icon" type="image/png" sizes="64x64"  href="/favicon-64x64.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" sizes="192x192"     href="/favicon.png?v=2" />

    <!-- Preconnect fonts (si usas Google Fonts, opcional) -->
    <!-- <link rel="preconnect" href="https://fonts.googleapis.com"> -->
    <!-- <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> -->

    <!-- Google Analytics 4 — reemplaza G-XXXXXXXXXX con tu ID real -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      // @ts-nocheck
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": SITE.name,
      "url": SITE.url,
      "description": SITE.description,
      "telephone": SITE.phone,
      "email": SITE.email,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": SITE.address,
        "addressLocality": "Baños de Agua Santa",
        "addressCountry": "EC"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -1.3989756,
        "longitude": -78.3707316
      },
      "openingHours": "Mo-Su 00:00-23:59",
      "priceRange": "$$",
      "image": SITE.ogImage,
      "sameAs": SITE.socials.map((s: { url: string }) => s.url)
    })} />
  </head>

  <body class="min-h-screen bg-white text-slate-900 antialiased">
    <!-- Fondo premium tipo “resort”: gradientes + textura sutil -->
    <div class="relative mx-auto max-w-7xl overflow-hidden px-4 sm:px-6 lg:px-8">
      <div class="absolute -top-48 left-1/2 h-[560px] w-[900px] -translate-x-1/2 rounded-full bg-emerald-500/10 blur-3xl"></div>
      <div class="absolute top-40 -left-32 h-[520px] w-[520px] rounded-full bg-cyan-500/10 blur-3xl"></div>
      <div class="absolute -bottom-48 right-0 h-[620px] w-[820px] rounded-full bg-indigo-500/10 blur-3xl"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.06),transparent_45%)]"></div>
      <div class="absolute inset-0 opacity-[0.08] [background-image:url('/noise.png')]"></div>
    </div>

    <Navbar lang={lang} />

    <main>
  <slot />
</main>
    <Footer lang={lang} />

    <WhatsAppFloat lang={lang} />

    <!-- GLightbox: lightbox para galerías -->
    <script>
      import GLightbox from 'glightbox';
      import 'glightbox/dist/css/glightbox.min.css';

      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-gallery]').forEach((grid) => {
          const groups = [...grid.querySelectorAll('.group.relative.overflow-hidden')];

          groups.forEach((group, startAt) => {
            const img = group.querySelector('img');
            if (!img) return;

            // Cursor zoom para indicar que es clickeable
            (group as HTMLElement).style.cursor = 'zoom-in';

            group.addEventListener('click', () => {
              const elements = groups
                .map((g) => g.querySelector('img'))
                .filter(Boolean)
                .map((i) => ({
                  href: (i as HTMLImageElement).getAttribute('src') ?? '',
                  alt:  (i as HTMLImageElement).getAttribute('alt')  ?? '',
                  type: 'image' as const,
                }));

              GLightbox({ elements, startAt, touchNavigation: true, loop: true }).open();
            });
          });
        });
      });
    </script>

    <!-- Micro-interacciones: reveal on scroll (ligero, sin librerías) -->
    <script>
      (() => {
        const els = document.querySelectorAll("[data-reveal]");
        if (!("IntersectionObserver" in window) || els.length === 0) return;

        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-revealed");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );

        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>

<style>
  /* Reveal animation: suave, premium, barato */
  [data-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 700ms ease, transform 700ms ease;
    will-change: opacity, transform;
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Scrollbar sutil (opcional) */
  :global(html) {
    scrollbar-color: rgba(148, 163, 184, 0.25) transparent;
  }
</style>