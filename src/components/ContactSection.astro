---
import { SITE } from "../config/site";

type Props = {
  lang?: "es" | "en";
};

const { lang = "es" } = Astro.props;
const isEs = lang === "es";

const content = isEs
  ? {
      eyebrow: "Contacto y ubicación",
      title: "Reserva tu próxima experiencia en Hostería Agoyán",
      subtitle:
        "Estamos listos para ayudarte con información, reservas y atención personalizada para tu próxima visita.",
      addressLabel: "Dirección",
      phoneLabel: "Teléfono",
      emailLabel: "Correo",
      hoursLabel: "Horario",
      hours: "Atención todos los días",
      whatsapp: "Escríbenos por WhatsApp",
      mapButton: "Cómo llegar",
      mapTitle: "Nuestra ubicación",
      fallbackMapText: "Ubícanos en Baños de Agua Santa, Ecuador.",
    }
  : {
      eyebrow: "Contact & location",
      title: "Book your next experience at Hostería Agoyán",
      subtitle:
        "We are ready to help you with information, bookings and personalized assistance for your next visit.",
      addressLabel: "Address",
      phoneLabel: "Phone",
      emailLabel: "Email",
      hoursLabel: "Hours",
      hours: "Available every day",
      whatsapp: "Chat on WhatsApp",
      mapButton: "Get directions",
      mapTitle: "Our location",
      fallbackMapText: "Find us in Baños de Agua Santa, Ecuador.",
    };

const waText = isEs
  ? `Hola, quiero información para reservar en ${SITE.name}.`
  : `Hi, I'd like information to book at ${SITE.name}.`;

const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);

const displayPhone =
  SITE.phone && SITE.phone.trim().length > 0
    ? SITE.phone
    : +`${SITE.whatsappNumber}`;
---

<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center" data-reveal>
      <p class="font-menu text-sm text-emerald-600">{content.eyebrow}</p>
      <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
        {content.title}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        {content.subtitle}
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1.05fr_1fr]">
      <!-- Left: Contact -->
      <div class="space-y-5" data-reveal>
        <!-- Número destacado -->
        <div class="overflow-hidden rounded-3xl border border-emerald-100 bg-white p-7 shadow-[0_10px_30px_rgba(0,0,0,0.06)]">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.08em] text-emerald-600">
                {content.phoneLabel}
              </p>
              <a
                href={`tel:${String(displayPhone).replace(/\s+/g, "")}`}
                class="mt-2 block text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
              >
                {displayPhone}
              </a>
              <p class="mt-2 text-sm text-slate-600">
                {isEs
                  ? "Contáctanos para reservas, promociones y atención personalizada."
                  : "Contact us for bookings, promotions and personalized assistance."}
              </p>
            </div>

            <a
              href={waUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center rounded-2xl border border-emerald-200 bg-emerald-50/70 px-5 py-3 text-sm font-semibold text-emerald-700 backdrop-blur transition hover:bg-emerald-100"
            >
              {content.whatsapp}
            </a>
          </div>
        </div>

        <!-- Cards -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
            <div class="text-sm font-semibold text-slate-900">{content.addressLabel}</div>
            <div class="mt-2 text-sm leading-7 text-slate-600">
              {SITE.address || content.fallbackMapText}
            </div>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
            <div class="text-sm font-semibold text-slate-900">{content.hoursLabel}</div>
            <div class="mt-2 text-sm leading-7 text-slate-600">
              {content.hours}
            </div>
          </div>

          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_8px_24px_rgba(0,0,0,0.04)] sm:col-span-2">
            <div class="text-sm font-semibold text-slate-900">{content.emailLabel}</div>
            <div class="mt-2 text-sm leading-7 text-slate-600">
              {SITE.email || "info@hosteriaagoyan.com"}
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Map -->
      <div data-reveal>
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-[0_16px_40px_rgba(0,0,0,0.08)]">
          <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
            <div>
              <h3 class="font-hero text-2xl text-slate-900">{content.mapTitle}</h3>
              <p class="mt-1 text-sm text-slate-500">
                {SITE.address || content.fallbackMapText}
              </p>
            </div>

            {SITE.googleMapsDirectionsUrl && (
              <a
                href={SITE.googleMapsDirectionsUrl}
                target="_blank"
                rel="noopener"
                class="hidden rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 sm:inline-flex"
              >
                {content.mapButton}
              </a>
            )}
          </div>

          {SITE.googleMapsEmbedUrl ? (
            <iframe
              src={SITE.googleMapsEmbedUrl}
              class="h-[460px] w-full border-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
              title={isEs ? "Mapa de ubicación de la hostería" : "Inn location map"}
            ></iframe>
          ) : (
            <div class="flex h-[460px] items-center justify-center bg-[linear-gradient(135deg,#f8fafc,#e2e8f0)] p-8 text-center">
              <div class="max-w-sm">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                  <svg viewBox="0 0 24 24" width="30" height="30" fill="none">
                    <path d="M12 21s6-4.35 6-11a6 6 0 1 0-12 0c0 6.65 6 11 6 11Z" stroke="currentColor" stroke-width="1.8"/>
                    <circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.8"/>
                  </svg>
                </div>

                <h4 class="mt-6 text-2xl font-semibold text-slate-900">
                  {content.mapTitle}
                </h4>
                <p class="mt-3 text-sm leading-7 text-slate-600">
                  {content.fallbackMapText}
                </p>
              </div>
            </div>
          )}
        </div>

        {SITE.googleMapsDirectionsUrl && (
          <a
            href={SITE.googleMapsDirectionsUrl}
            target="_blank"
            rel="noopener"
            class="mt-4 inline-flex rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 transition hover:bg-slate-100 sm:hidden"
          >
            {content.mapButton}
          </a>
        )}
      </div>
    </div>
  </div>
</section>