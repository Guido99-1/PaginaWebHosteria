---
type FacilityItem = {
  title: string;
  description: string;
  icon: string;
  href?: string;
};

type Props = {
  lang?: "es" | "en";
  items: FacilityItem[];
};

const { lang = "es", items } = Astro.props;
const isEs = lang === "es";

const content = isEs
  ? {
      eyebrow: "Instalaciones y servicios",
      title: "Espacios y servicios para una experiencia completa",
      subtitle:
        "Disfruta de instalaciones cómodas y servicios pensados para tu descanso, bienestar y comodidad.",
      button: "Ver más",
    }
  : {
      eyebrow: "Facilities & services",
      title: "Spaces and services for a complete experience",
      subtitle:
        "Enjoy comfortable facilities and services designed for your rest, wellness and convenience.",
      button: "View more",
    };
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto mb-14 max-w-3xl text-center" data-reveal>
      <p class="font-menu text-sm text-sky-600">{content.eyebrow}</p>
      <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
        {content.title}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        {content.subtitle}
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <article class="service-card group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-8" data-reveal>
          <div class="service-line"></div>

          {item.href ? (
            <a href={item.href} class="block">
              <div class="service-icon text-emerald-500">
                <span set:html={item.icon} />
              </div>

              <h3 class="mt-6 font-hero text-2xl text-slate-900 transition duration-300 group-hover:text-slate-950">
                {item.title}
              </h3>

              <p class="mt-4 text-sm leading-7 text-slate-600">
                {item.description}
              </p>

              <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-sky-700 transition duration-300 group-hover:text-emerald-600">
                <span>{content.button}</span>
                <span aria-hidden="true">→</span>
              </div>
            </a>
          ) : (
            <>
              <div class="service-icon text-emerald-500">
                <span set:html={item.icon} />
              </div>

              <h3 class="mt-6 font-hero text-2xl text-slate-900 transition duration-300 group-hover:text-slate-950">
                {item.title}
              </h3>

              <p class="mt-4 text-sm leading-7 text-slate-600">
                {item.description}
              </p>
            </>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-card {
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease,
      background-color 0.35s ease;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  }

  .service-card:hover {
    transform: translateY(-6px);
    border-color: rgba(16, 185, 129, 0.22);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.10);
    background: #ffffff;
  }

  .service-line {
    position: absolute;
    left: 0;
    top: 0;
    height: 3px;
    width: 0;
    background: linear-gradient(90deg, #0ea5e9, #10b981);
    transition: width 0.35s ease;
  }

  .service-card:hover .service-line {
    width: 100%;
  }

  .service-icon {
    transition:
      transform 0.35s ease,
      color 0.35s ease,
      filter 0.35s ease;
  }

  .service-card:hover .service-icon {
    transform: translateY(-4px) scale(1.08);
    color: #0ea5e9;
    filter: drop-shadow(0 8px 14px rgba(14, 165, 233, 0.18));
  }

  .service-icon :global(svg) {
    width: 54px;
    height: 54px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
  }
</style>