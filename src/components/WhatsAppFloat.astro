---
import { SITE } from "../config/site";

type Props = {
  lang?: "es" | "en";
};

const { lang = "es" } = Astro.props;
const isEs = lang === "es";

const msg = isEs
  ? `Hola, quiero información para reservar en ${SITE.name}.`
  : `Hi, I'd like information to book at ${SITE.name}.`;

const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(msg);
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener"
  class="wa-float group fixed bottom-5 right-5 z-50"
  aria-label={isEs ? "Reservar por WhatsApp" : "Book on WhatsApp"}
>
  <span class="wa-glow" aria-hidden="true"></span>

  <span class="wa-shell">
    <span class="wa-icon-wrap">
      <svg class="wa-icon" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <path
          d="M16 5.2c-5.8 0-10.5 4.4-10.5 9.9 0 2 .6 3.9 1.8 5.6L6 25.6l5-1.3c1.4.8 3 1.2 4.9 1.2 5.8 0 10.5-4.4 10.5-9.9S21.8 5.2 16 5.2Z"
          fill="white"
        />
        <path
          d="M13 12.1c.2-.5.5-.6.8-.6h.5c.3 0 .5.2.6.5l.7 1.8c.1.3.1.7-.2 1l-.6.7c-.1.2-.2.4-.1.6.5.9 1.2 1.7 2.2 2.4.2.2.5.2.7 0l.7-.5c.3-.2.7-.3 1-.2l1.8.7c.4.2.6.5.6.8v.5c0 .5-.2.8-.6 1-.7.3-1.4.4-2 .3-1.8-.3-3.6-1.2-5.2-2.8-1.5-1.5-2.5-3.2-2.9-5-.1-.7 0-1.4.2-2Z"
          fill="#16a34a"
        />
      </svg>

      <span class="wa-dot"></span>
    </span>

    <span class="wa-text hidden sm:flex">
      <span class="wa-kicker">
        {isEs ? "Atención inmediata" : "Instant support"}
      </span>
      <span class="wa-title">
        {isEs ? "Reservar por WhatsApp" : "Book on WhatsApp"}
      </span>
    </span>

    <span class="wa-mobile sm:hidden">
      WhatsApp
    </span>
  </span>
</a>

<style>
  .wa-float {
    animation: waFadeIn 0.45s ease both;
  }

  .wa-glow {
    position: absolute;
    inset: auto 8px 4px 8px;
    height: 26px;
    border-radius: 9999px;
    background: rgba(34, 197, 94, 0.32);
    filter: blur(18px);
    z-index: -1;
    transition: opacity 0.3s ease, transform 0.3s ease;
    opacity: 0.8;
  }

  .wa-shell {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(51, 65, 85, 0.88);
    padding: 0.82rem 1rem;
    color: white;
    box-shadow:
      0 16px 34px rgba(0, 0, 0, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition:
      transform 0.28s ease,
      background-color 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease;
  }

  .wa-float:hover .wa-shell {
    transform: translateY(-2px);
    background: rgba(51, 65, 85, 0.95);
    border-color: rgba(74, 222, 128, 0.28);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.22),
      0 0 0 1px rgba(74, 222, 128, 0.08) inset;
  }

  .wa-float:hover .wa-glow {
    opacity: 1;
    transform: scale(1.05);
  }

  .wa-icon-wrap {
    position: relative;
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 9999px;
    background:
      radial-gradient(circle at 30% 28%, #4ade80 0%, #22c55e 38%, #16a34a 68%, #15803d 100%);
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.28),
      inset 0 -4px 10px rgba(0, 0, 0, 0.18),
      0 10px 22px rgba(34, 197, 94, 0.24);
    flex-shrink: 0;
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      filter 0.28s ease;
  }

  .wa-float:hover .wa-icon-wrap {
    transform: scale(1.05);
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.3),
      inset 0 -4px 10px rgba(0, 0, 0, 0.2),
      0 14px 26px rgba(34, 197, 94, 0.3);
    filter: brightness(1.03);
  }

  .wa-icon {
    width: 1.45rem;
    height: 1.45rem;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.08));
  }

  .wa-dot {
    position: absolute;
    right: 0.08rem;
    top: 0.08rem;
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 9999px;
    background: #22c55e;
    box-shadow:
      0 0 0 3px rgba(51, 65, 85, 0.95),
      0 0 12px rgba(34, 197, 94, 0.55);
    animation: waPulse 1.8s infinite;
  }

  .wa-text {
    display: flex;
    flex-direction: column;
    line-height: 1.08;
  }

  .wa-kicker {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.68);
    margin-bottom: 0.18rem;
  }

  .wa-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
    white-space: nowrap;
  }

  .wa-mobile {
    font-size: 0.92rem;
    font-weight: 700;
    white-space: nowrap;
  }

  @keyframes waPulse {
    0% {
      transform: scale(1);
      box-shadow:
        0 0 0 3px rgba(51, 65, 85, 0.95),
        0 0 0 0 rgba(34, 197, 94, 0.4);
    }
    70% {
      transform: scale(1);
      box-shadow:
        0 0 0 3px rgba(51, 65, 85, 0.95),
        0 0 0 9px rgba(34, 197, 94, 0);
    }
    100% {
      transform: scale(1);
      box-shadow:
        0 0 0 3px rgba(51, 65, 85, 0.95),
        0 0 0 0 rgba(34, 197, 94, 0);
    }
  }

  @keyframes waFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 640px) {
    .wa-shell {
      padding: 0.8rem 0.95rem;
      gap: 0.72rem;
    }

    .wa-icon-wrap {
      width: 2.9rem;
      height: 2.9rem;
    }

    .wa-icon {
      width: 1.32rem;
      height: 1.32rem;
    }
  }
</style>