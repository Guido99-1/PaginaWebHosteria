---
import { SITE } from "../config/site";

type Props = {
  lang?: "es" | "en";
};

const { lang = "es" } = Astro.props;
const isEs = lang === "es";

const content = isEs
  ? {
      eyebrow: "BIENVENIDOS",
      title: "Un refugio de naturaleza y bienestar en Baños de Agua Santa",
      subtitle:
        "En Hostería Agoyán encontrarás el equilibrio perfecto entre la tranquilidad de la naturaleza y el confort que mereces. Espacios únicos para descansar, disfrutar y crear recuerdos inolvidables.",
      cta: "Ver nuestros paquetes",
      ctaHref: "/es/paquetes/",
      secondaryCta: "Conoce las instalaciones",
      secondaryHref: "/es/instalaciones/",
      pillars: [
        {
          icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Z"/><path d="M2 12h4m12 0h4M12 2v4m0 12v4"/><path d="M6.34 6.34l2.83 2.83m5.66 5.66 2.83 2.83M17.66 6.34l-2.83 2.83M9.17 14.83l-2.83 2.83"/></svg>`,
          title: "Naturaleza",
          desc: "Rodeados de paisajes verdes y el ambiente único de Baños de Agua Santa, a pasos de la naturaleza.",
        },
        {
          icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 17h18M5 17V9a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v8"/><path d="M9 17v-5h6v5"/></svg>`,
          title: "Confort",
          desc: "Habitaciones acogedoras, piscina, sauna y turco para una experiencia de bienestar completa.",
        },
        {
          icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
          title: "Experiencias",
          desc: "Paquetes y promociones pensados para parejas, familias y grupos que buscan momentos especiales.",
        },
      ],
      stats: [
        { value: "10+", label: "Años de experiencia" },
        { value: "6★", label: "Valoración en Google" },
        { value: "365", label: "Días al año" },
      ],
    }
  : {
      eyebrow: "WELCOME",
      title: "A sanctuary of nature and wellness in Baños de Agua Santa",
      subtitle:
        "At Hostería Agoyán you'll find the perfect balance between the tranquility of nature and the comfort you deserve. Unique spaces to rest, enjoy and create unforgettable memories.",
      cta: "View our packages",
      ctaHref: "/en/packages/",
      secondaryCta: "Explore facilities",
      secondaryHref: "/en/facilities/",
      pillars: [
        {
          icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Z"/><path d="M2 12h4m12 0h4M12 2v4m0 12v4"/><path d="M6.34 6.34l2.83 2.83m5.66 5.66 2.83 2.83M17.66 6.34l-2.83 2.83M9.17 14.83l-2.83 2.83"/></svg>`,
          title: "Nature",
          desc: "Surrounded by green landscapes and the unique atmosphere of Baños de Agua Santa.",
        },
        {
          icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 17h18M5 17V9a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v8"/><path d="M9 17v-5h6v5"/></svg>`,
          title: "Comfort",
          desc: "Cozy rooms, pool, sauna and steam room for a complete wellness experience.",
        },
        {
          icon: `<svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
          title: "Experiences",
          desc: "Packages and promotions designed for couples, families and groups.",
        },
      ],
      stats: [
        { value: "10+", label: "Years of experience" },
        { value: "5★", label: "Google rating" },
        { value: "365", label: "Days a year" },
      ],
    };
---

<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-14 lg:grid-cols-2 lg:gap-20">

      <!-- Columna izquierda: texto -->
      <div data-reveal>
        <p class="font-menu text-sm tracking-[0.18em] text-emerald-600 uppercase">
          {content.eyebrow}
        </p>

        <h2 class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl lg:text-6xl">
          {content.title}
        </h2>

        <p class="mt-6 text-base leading-8 text-slate-600 sm:text-lg">
          {content.subtitle}
        </p>

        <!-- Stats -->
        <div class="mt-10 grid grid-cols-3 gap-4 border-y border-slate-100 py-8">
          {content.stats.map((s) => (
            <div class="text-center">
              <p class="font-hero text-3xl font-bold text-emerald-600 sm:text-4xl">{s.value}</p>
              <p class="mt-1 text-xs leading-5 text-slate-500">{s.label}</p>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={content.ctaHref}
            class="welcome-cta inline-flex items-center justify-center rounded-2xl px-7 py-3.5 text-sm font-semibold text-white"
          >
            {content.cta}
          </a>
          <a
            href={content.secondaryHref}
            class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-7 py-3.5 text-sm font-semibold text-slate-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700"
          >
            {content.secondaryCta}
          </a>
        </div>
      </div>

      <!-- Columna derecha: pilares -->
      <div class="space-y-5" data-reveal>
        {content.pillars.map((p) => (
          <div class="pillar-card group flex items-start gap-5 rounded-2xl border border-slate-100 bg-slate-50 p-6 transition">
            <div class="pillar-icon flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-xl bg-white text-emerald-500 shadow-sm ring-1 ring-slate-200 transition group-hover:bg-emerald-500 group-hover:text-white group-hover:ring-emerald-400">
              <span set:html={p.icon} />
            </div>
            <div>
              <h3 class="font-hero text-xl text-slate-900">{p.title}</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .welcome-cta {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 14px 30px rgba(16, 185, 129, 0.22);
    transition: transform 0.25s ease, filter 0.25s ease, box-shadow 0.25s ease;
  }
  .welcome-cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.04);
    box-shadow: 0 18px 36px rgba(16, 185, 129, 0.28);
  }

  .pillar-card {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
  }
  .pillar-card:hover {
    border-color: rgba(16, 185, 129, 0.2);
    background: #fff;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.07);
    transform: translateY(-2px);
  }

  .pillar-icon :global(svg) {
    transition: inherit;
  }
</style>
