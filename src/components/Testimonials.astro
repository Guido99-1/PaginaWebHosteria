---
type TestimonialItem = {
  name: string;
  comment: string;
  rating: number;
  source?: string;
  date?: string;
};

type Props = {
  lang?: "es" | "en";
  items: TestimonialItem[];
  googleReviewsUrl?: string;
};

const {
  lang = "es",
  items,
  googleReviewsUrl = "https://www.google.com/maps",
} = Astro.props;

const isEs = lang === "es";

const content = isEs
  ? {
      eyebrow: "Opiniones de nuestros huéspedes",
      title: "Lo que dicen nuestros visitantes",
      subtitle:
        "Comentarios destacados de personas que disfrutaron su experiencia en Hostería Agoyán.",
      button: "Ver más reseñas en Google",
      sourceFallback: "Google",
    }
  : {
      eyebrow: "Guest reviews",
      title: "What our visitors say",
      subtitle:
        "Featured comments from people who enjoyed their experience at Hostería Agoyán.",
      button: "See more reviews on Google",
      sourceFallback: "Google",
    };

const renderStars = (rating: number) => {
  const safeRating = Math.max(0, Math.min(5, Math.round(rating)));
  return Array.from({ length: 5 }, (_, i) => i < safeRating);
};
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto mb-14 max-w-3xl text-center" data-reveal>
      <p class="font-menu text-sm text-amber-600">{content.eyebrow}</p>
      <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
        {content.title}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        {content.subtitle}
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {items.map((item) => (
        <article
          class="group relative overflow-hidden rounded-3xl border border-slate-200 bg-slate-50 p-7 transition duration-300 hover:-translate-y-1 hover:border-amber-200 hover:bg-white hover:shadow-[0_18px_45px_rgba(0,0,0,0.08)]"
          data-reveal
        >
          <!-- Comillas decorativas -->
          <div class="absolute right-5 top-4 text-6xl font-serif text-amber-100 transition duration-300 group-hover:text-amber-200">
            “
          </div>

          <!-- Stars -->
          <div class="flex items-center gap-1">
            {renderStars(item.rating).map((filled) => (
              <svg
                viewBox="0 0 24 24"
                class={`h-5 w-5 ${filled ? "text-amber-400" : "text-slate-300"}`}
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 2.5l2.93 5.94 6.56.95-4.74 4.62 1.12 6.53L12 17.77 6.13 20.54l1.12-6.53L2.5 9.39l6.56-.95L12 2.5z" />
              </svg>
            ))}
          </div>

          <!-- Comment -->
          <p class="mt-5 text-[15px] leading-7 text-slate-600">
            {item.comment}
          </p>

          <!-- Footer -->
          <div class="mt-7 border-t border-slate-200 pt-5">
            <div class="text-base font-semibold text-slate-900">
              {item.name}
            </div>

            <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500">
              <span>{item.source || content.sourceFallback}</span>
              {item.date && (
                <>
                  <span class="text-slate-300">•</span>
                  <span>{item.date}</span>
                </>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center" data-reveal>
      <a
        href={googleReviewsUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:border-amber-300 hover:bg-amber-50"
      >
        {content.button}
      </a>
    </div>
  </div>
</section>