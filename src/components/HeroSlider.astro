---
import { SITE } from "../config/site";

type Slide = {
  title: string;
  subtitle: string;
  image: string;
  ctaText: string;
  ctaHref: string;
};

type Props = {
  lang?: "es" | "en";
  slides: Slide[];
};

const { lang = "es", slides } = Astro.props;
const isEs = lang === "es";

const waText = isEs
  ? `Hola, quiero información para reservar en ${SITE.name}.`
  : `Hi, I'd like information to book at ${SITE.name}.`;

const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<section class="relative -mx-4 sm:-mx-6 lg:-mx-8" aria-label="Hero">
  <div class="relative h-[92vh] min-h-[540px] w-full overflow-hidden">
    <div class="swiper hero-swiper h-full">
      <div class="swiper-wrapper h-full">
        {slides.map((s) => (
          <div class="swiper-slide h-full">
            <div class="relative h-full w-full">
              <img
                src={s.image}
                alt={s.title}
                class="hero-image absolute inset-0 h-full w-full object-cover"
                loading="eager"
              />

              <!-- Overlay oscuro en la foto-->
              <div class="absolute inset-0 bg-black/20"></div>
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/45 via-slate-950/10 to-transparent"></div>

              <!-- Content -->
              <div class="absolute inset-x-0 bottom-0">
                <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-14 sm:pb-20">
                  <div class="max-w-3xl">
                    <h1 class="hero-title font-hero text-4xl sm:text-6xl lg:text-7xl font-medium tracking-wide text-white drop-shadow-[0_3px_12px_rgba(0,0,0,0.45)]">
                      {s.title}
                    </h1>

                    <p class="hero-subtitle mt-4 max-w-2xl text-sm sm:text-base lg:text-lg text-white/90 leading-relaxed">
                      {s.subtitle}
                    </p>

                    <div class="hero-actions mt-7 flex flex-col gap-3 sm:flex-row">
                      <a
                        href={s.ctaHref}
                        class="inline-flex items-center justify-center rounded-2xl border border-white/50 bg-white/12 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/22"
                      >
                        {s.ctaText}
                      </a>

                      <a
                        href={waUrl}
                        target="_blank"
                        rel="noopener"
                        class="hero-wa inline-flex items-center justify-center gap-2 rounded-2xl px-7 py-3.5 text-sm font-semibold text-white transition"
                      >
                        <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
                          <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                        </svg>
                        {isEs ? "Reservar por WhatsApp" : "Book on WhatsApp"}
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Flechas -->
      <button
        class="hero-prev absolute left-3 top-1/2 z-20 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full border border-white/20 bg-black/30 text-white backdrop-blur transition hover:bg-black/50 hover:border-white/40 sm:left-6"
        aria-label="Slide anterior"
        type="button"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button
        class="hero-next absolute right-3 top-1/2 z-20 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full border border-white/20 bg-black/30 text-white backdrop-blur transition hover:bg-black/50 hover:border-white/40 sm:right-6"
        aria-label="Siguiente slide"
        type="button"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Paginación -->
      <div class="hero-pagination absolute bottom-4 left-1/2 z-20 -translate-x-1/2"></div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay, EffectFade } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/effect-fade";
  import "swiper/css/pagination";

  (() => {
    const el = document.querySelector<HTMLElement>(".hero-swiper");
    if (!el) return;

    new Swiper(el, {
      modules: [Navigation, Pagination, Autoplay, EffectFade],
      effect: "fade",
      fadeEffect: { crossFade: true },
      rewind: true,
      speed: 900,
      autoplay: { delay: 6500, disableOnInteraction: false },
      pagination: { el: ".hero-pagination", clickable: true },
      navigation: { nextEl: ".hero-next", prevEl: ".hero-prev" },
    });
  })();
</script>

<style>
  .hero-wa {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 14px 30px rgba(16, 185, 129, 0.28);
    transition: transform 0.25s ease, filter 0.25s ease, box-shadow 0.25s ease;
  }
  .hero-wa:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 18px 36px rgba(16, 185, 129, 0.34);
  }

  .hero-pagination :global(.swiper-pagination-bullet) {
    width: 9px;
    height: 9px;
    opacity: 0.55;
    background: rgba(255, 255, 255, 0.85);
  }

  .hero-pagination :global(.swiper-pagination-bullet-active) {
    opacity: 1;
  }

  .hero-image {
    transform: scale(1);
  }

  /* :global(.swiper-slide-active) .hero-image {
    animation: heroImageZoom 6.8s ease forwards;
  } */

  .hero-title,
  .hero-subtitle,
  .hero-actions {
    opacity: 0;
    will-change: transform, opacity;
  }

  :global(.swiper-slide-active) .hero-title {
    animation: heroTitleIn 0.9s ease forwards;
  }

  :global(.swiper-slide-active) .hero-subtitle {
    animation: heroSubtitleIn 0.9s ease forwards;
    animation-delay: 0.25s;
  }

  :global(.swiper-slide-active) .hero-actions {
    animation: heroButtonsIn 0.9s ease forwards;
    animation-delay: 0.45s;
  }

  /* @keyframes heroImageZoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.06);
    }
  } */

  @keyframes heroTitleIn {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroSubtitleIn {
    from {
      opacity: 0;
      transform: translateX(-35px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes heroButtonsIn {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>