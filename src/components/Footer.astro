---
import { SITE } from "../config/site";

type Props = {
  lang?: "es" | "en";
};

const { lang = "es" } = Astro.props;
const isEs = lang === "es";
const year = new Date().getFullYear();

const content = isEs
  ? {
      tagline: "Naturaleza, descanso y bienestar en Baños de Agua Santa.",
      navTitle: "Navegación",
      contactTitle: "Contacto",
      socialTitle: "Síguenos",
      home: "Inicio",
      packages: "Paquetes",
      promotions: "Promociones",
      facilities: "Instalaciones",
      contact: "Contacto",
      rights: "Todos los derechos reservados.",
      phone: "Teléfono",
      address: "Dirección",
    }
  : {
      tagline: "Nature, rest and wellness in Baños de Agua Santa.",
      navTitle: "Navigation",
      contactTitle: "Contact",
      socialTitle: "Follow us",
      home: "Home",
      packages: "Packages",
      promotions: "Promotions",
      facilities: "Facilities",
      contact: "Contact",
      rights: "All rights reserved.",
      phone: "Phone",
      address: "Address",
    };

const base = `/${lang}`;

const links = [
  { label: content.home, href: `${base}/`},
  { label: content.packages, href: isEs ? "/es/paquetes/" : "/en/packages/" },
  { label: content.promotions, href: isEs ? "/es/promociones/" : "/en/promotions/" },
  { label: content.facilities, href: isEs ? "/es/instalaciones/" : "/en/facilities/" },
  { label: content.contact, href: isEs ? "/es/contacto/" : "/en/contact/" },
];

const waText = isEs
  ? `Hola, quiero información para reservar en ${SITE.name}.`
  : `Hi, I'd like information to book at ${SITE.name}.`;

const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);

const displayPhone =
  SITE.phone && String(SITE.phone).trim().length > 0
    ? String(SITE.phone)
    : `+${SITE.whatsappNumber}`;

const socialIcon = (label: string) => {
  const key = label.toLowerCase();

  if (key.includes("instagram")) {
    return `
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="17.2" cy="6.8" r="1" fill="currentColor"/>
      </svg>
    `;
  }

  if (key.includes("facebook")) {
    return `
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M13.5 21v-7h2.5l.5-3h-3V9.3c0-.9.3-1.5 1.6-1.5H16V5.1c-.3 0-1.2-.1-2.3-.1-2.3 0-3.8 1.4-3.8 4V11H7v3h2.6v7h3.9Z" fill="currentColor"/>
      </svg>
    `;
  }

  if (key.includes("tiktok")) {
    return `
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M14 3c.5 2 1.8 3.5 4 4v2.7c-1.5 0-2.8-.4-4-1.2v5.1c0 3-2.2 5.3-5.2 5.3S3.5 16.6 3.5 13.7c0-3 2.2-5.3 5.2-5.3.3 0 .6 0 .8.1v2.8a2.7 2.7 0 0 0-.8-.1c-1.4 0-2.5 1.1-2.5 2.5s1.1 2.6 2.5 2.6c1.5 0 2.5-1.2 2.5-2.8V3H14Z" fill="currentColor"/>
      </svg>
    `;
  }

  return `
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/>
    </svg>
    `;
};
---

<footer class="footer-elegant text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr_0.9fr_0.9fr]">
      <!-- Marca -->
      <div data-reveal>
        <a href={`${base}/`} class="flex items-center gap-4">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-white/95 p-1.5 shadow-lg ring-1 ring-white/10">
            <img
              src="/logo-agoyan.png"
              alt="Logo Hostería Agoyán"
              class="h-full w-full object-contain"
            />
          </div>

          <div class="leading-tight">
            <div class="text-[1.05rem] font-extrabold uppercase tracking-[0.1em] text-white">
              {SITE.name}
            </div>
            <div class="mt-0.5 text-xs font-medium tracking-[0.04em] text-white/70">
              {isEs ? "Baños de Agua Santa" : "Baños de Agua Santa, Ecuador"}
            </div>
          </div>
        </a>

        <p class="mt-6 max-w-md text-sm leading-7 text-white/72">
          {content.tagline}
        </p>

        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="footer-cta mt-6 inline-flex items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold text-white"
        >
          WhatsApp
        </a>
      </div>

      <!-- Navegación -->
      <div data-reveal>
        <h3 class="footer-title">{content.navTitle}</h3>
        <nav class="mt-5 grid gap-3">
          {links.map((link) => (
            <a href={link.href} class="footer-link text-sm">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contacto -->
      <div data-reveal>
        <h3 class="footer-title">{content.contactTitle}</h3>
        <div class="mt-5 grid gap-5 text-sm text-white/72">
          <div>
            <div class="font-semibold text-white/92">{content.phone}</div>
            <a
              href={`tel:${displayPhone.replace(/\s+/g, "")}`}
              class="footer-link mt-1 block"
            >
              {displayPhone}
            </a>
          </div>

          <div>
            <div class="font-semibold text-white/92">Email</div>
            <a
              href={`mailto:${SITE.email}`}
              class="footer-link mt-1 block"
            >
              {SITE.email}
            </a>
          </div>

          <div>
            <div class="font-semibold text-white/92">{content.address}</div>
            <div class="mt-1 text-white/72">
              {SITE.address}
            </div>
          </div>
        </div>
      </div>

      <!-- Redes -->
      <div data-reveal>
        <h3 class="footer-title">{content.socialTitle}</h3>

        <div class="mt-5 flex flex-wrap gap-3">
          {(SITE.socials ?? []).map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener"
              class="social-pill inline-flex items-center gap-3 rounded-2xl px-4 py-3 text-sm"
            >
              <span class="social-icon" set:html={socialIcon(social.label)} />
              <span>{social.label}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-6" data-reveal>
      <div class="flex flex-col gap-3 text-sm text-white/55 sm:flex-row sm:items-center sm:justify-between">
        <p>
          © {year} {SITE.name}. {content.rights}
        </p>

        <a
          href={SITE.url}
          target="_blank"
          rel="noopener"
          class="footer-link"
        >
          {SITE.url.replace("https://", "")}
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-elegant {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(52, 211, 153, 0.08), transparent 28%),
      radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.06), transparent 30%),
      linear-gradient(180deg, #223126 0%, #1c271f 100%);
  }

  .footer-title {
    font-family: "Oswald", sans-serif;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
  }

  .footer-cta {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 14px 30px rgba(16, 185, 129, 0.22);
    transition: transform 0.3s ease, box-shadow 0.3s ease, filter 0.3s ease;
  }

  .footer-cta:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
    box-shadow: 0 18px 36px rgba(16, 185, 129, 0.28);
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.72);
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .footer-link:hover {
    color: #86efac;
    transform: translateX(2px);
  }

  .social-pill {
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.78);
    transition:
      border-color 0.25s ease,
      background-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease,
      color 0.25s ease;
  }

  .social-pill:hover {
    transform: translateY(-2px);
    border-color: rgba(134, 239, 172, 0.28);
    background: rgba(255, 255, 255, 0.08);
    color: #86efac;
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.14);
  }

  .social-icon :global(svg) {
    width: 18px;
    height: 18px;
    color: currentColor;
  }

  .social-icon {
    transition: transform 0.25s ease;
  }

  .social-pill:hover .social-icon {
    transform: scale(1.06);
  }
</style>