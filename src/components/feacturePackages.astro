---
type PackageItem = {
  title: string;
  price: string;
  description: string;
  image: string;
  href: string;
};

type Props = {
  lang?: "es" | "en";
  packages: PackageItem[];
};

const { lang = "es", packages } = Astro.props;
const isEs = lang === "es";

const content = isEs
  ? {
      eyebrow: "Paquetes destacados",
      title: "Experiencias pensadas para descansar y disfrutar",
      subtitle:
        "Descubre opciones ideales para pareja, familia o amigos, con espacios cómodos y un ambiente natural único.",
      button: "Ver más",
    }
  : {
      eyebrow: "Featured packages",
      title: "Experiences designed for rest and enjoyment",
      subtitle:
        "Discover ideal options for couples, families or friends, with comfortable spaces and a unique natural atmosphere.",
      button: "View more",
    };
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <p class="font-menu text-sm text-sky-600">{content.eyebrow}</p>
      <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
        {content.title}
      </h2>
      <p class="mt-4 text-base leading-relaxed text-slate-600">
        {content.subtitle}
      </p>
    </div>

    <!-- Cards -->
    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {packages.map((item) => (
        <article class="group overflow-hidden rounded-2xl bg-white shadow-[0_10px_30px_rgba(0,0,0,0.08)] ring-1 ring-slate-200 transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(0,0,0,0.12)]">
          <a href={item.href} class="block">
            <div class="relative h-72 overflow-hidden">
              <img
                src={item.image}
                alt={item.title}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/10 to-transparent"></div>

              <div class="absolute bottom-4 left-4">
                <span class="rounded-full bg-white/95 px-4 py-2 text-sm font-semibold text-slate-900 shadow">
                  {item.price}
                </span>
              </div>
            </div>

            <div class="p-6">
              <h3 class="font-menu text-xl text-slate-900">
                {item.title}
              </h3>

              <p class="mt-3 text-sm leading-6 text-slate-600">
                {item.description}
              </p>

              <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-sky-700 transition group-hover:text-sky-500">
                <span>{content.button}</span>
                <span aria-hidden="true">→</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>