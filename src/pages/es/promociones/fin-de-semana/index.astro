---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { SITE } from "../../../../config/site";

const promo = {
  title: "Oferta especial entre semana",
  eyebrow: "OFERTA DE ENTRE SEMANA",
  subtitle:
    "Aprovecha de domingo a jueves al máximo: tarifas especiales, acceso completo a la piscina, sauna, turco y áreas verdes en Hostería Agoyán — la escapada perfecta para desconectarte de la semana.",
  price: "$25",
  priceNote: "por persona",
  duration: "Fin de semana",
  guests: "Parejas, amigos o familia",
  availability: "Domingo a jueves - Aplica condisiones",
  heroImage: "/imagenes/instalaciones/FullDay2.jpg",
  gallery: [
    { src: "/imagenes/instalaciones/Familia2.jpg", alt: "Fin de semana en Hostería Agoyán" },
    { src: "/imagenes/instalaciones/Familia4.jpg",        alt: "Áreas recreativas" },
    { src: "/imagenes/instalaciones/Piscina.jpeg",       alt: "Piscina y zona de bienestar" },
    { src: "/imagenes/instalaciones/AreasVerdes.jpeg",   alt: "Áreas verdes y naturaleza" },
  ],
  includes: [
    "Tarifa promocional especial — domingo a jueves",
    "Acceso a piscina, sauna, turco e hidromasaje",
    "Áreas verdes y espacios de relajación",
    "Salón de juegos",
    "Desayuno incluido para hospedaje",
    "Parqueadero privado seguro y espacioso",
    "Wi-Fi en toda la propiedad",
    "Atención personalizada de nuestro equipo",
  ],
  extras: [
    "Almuerzo o cena opcional (costo adicional)",
    "Decoración especial para celebraciones o momentos románticos",
    "Apoyo para reservas grupales o eventos especiales",
    "Upgrade a habitación o cabaña (costo adicional)",
    "Paquetes de tours en Baños (costo adicional)",
  ],
  conditions: [
    "Válida entre de semana: domimgo a jueves",
    "Sujeta a disponibilidad — se recomienda reserva anticipada",
    "No combinable con otras promociones",
    "No reembolsable una vez confirmada la reserva",
    "Consulta tarifas para grupos o fechas especiales",
  ],
};

const related = [
  {
    title: "Promoción de Temporada",
    href: "/es/promociones/temporada/",
    image: "/imagenes/instalaciones/comedorHosteria.jpeg",
  },
];

const waText = `Hola, quiero información sobre la ${promo.title} en ${SITE.name}.`;
const waUrl  = `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout lang="es" title={`${promo.title} | ${SITE.name}`} description={promo.subtitle}>

  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative h-[82vh] min-h-[600px] overflow-hidden">
      <img
        src={promo.heroImage}
        alt={promo.title}
        class="absolute inset-0 h-full w-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/10"></div>

      <div class="relative z-10 mx-auto flex h-full max-w-7xl items-end px-4 pb-14 pt-28 sm:px-6 lg:px-8">
        <div class="grid w-full gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">

          <!-- texto izquierda -->
          <div data-reveal>
            <div class="mb-4 flex items-center gap-2 font-menu text-xs tracking-[0.16em] text-white/55">
              <a href="/es/promociones/" class="transition hover:text-white/90">PROMOCIONES</a>
              <span>/</span>
              <span class="text-emerald-300">{promo.eyebrow}</span>
            </div>
            <h1 class="font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">
              {promo.title}
            </h1>
            <p class="mt-5 max-w-2xl text-base leading-8 text-white/82 sm:text-lg">
              {promo.subtitle}
            </p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a
                href={waUrl}
                target="_blank"
                rel="noopener"
                class="hero-wa-btn inline-flex items-center justify-center gap-2.5 rounded-2xl px-7 py-3.5 text-sm font-bold text-white"
              >
                <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
                  <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
                </svg>
                Reservar por WhatsApp
              </a>
              <a
                href="#incluye"
                class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/30 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18"
              >
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                Ver qué incluye
              </a>
            </div>
          </div>

          <!-- tarjeta de precio -->
          <aside
            class="price-card rounded-[2rem] border border-white/20 p-6 text-white shadow-[0_24px_60px_rgba(0,0,0,0.3)] backdrop-blur-xl"
            data-reveal
          >
            <div class="font-menu text-xs tracking-[0.14em] text-white/60">PROMOCIÓN DESDE</div>
            <div class="mt-3 font-hero text-6xl font-bold leading-none text-white">{promo.price}</div>
            <div class="mt-1.5 text-sm text-white/65">{promo.priceNote}</div>
            <div class="mt-6 grid grid-cols-2 gap-2.5">
              {[
                { label: "Duración",        value: promo.duration },
                { label: "Para",            value: promo.guests },
                { label: "Disponibilidad",  value: promo.availability },
                { label: "Reserva",         value: "Directa" },
              ].map((d) => (
                <div class="rounded-2xl border border-white/10 bg-black/20 p-3.5">
                  <div class="text-[10px] font-menu tracking-wider text-white/55">{d.label}</div>
                  <div class="mt-1 text-sm font-semibold text-white">{d.value}</div>
                </div>
              ))}
            </div>
            <a
              href={waUrl}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-white px-5 py-3 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50"
            >
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
              </svg>
              Consultar disponibilidad
            </a>
          </aside>
        </div>
      </div>

      <!-- scroll arrow -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/45">
        <span class="font-menu text-[10px] tracking-widest">EXPLORAR</span>
        <svg class="scroll-arrow" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ INTRO ═══════════════════════════════════════ -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">

        <div data-reveal>
          <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">IDEAL PARA ESCAPARTE</p>
          <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
            Disfruta tu inicio de semana con una tarifa especial
          </h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            La Promoción de inicio de Semana está pensada para quienes quieren
            aprovechar al máximo su domingo a jueves sin gastar de más. Acceso
            completo a la zona de bienestar, áreas verdes y espacios de
            relajación — todo a una tarifa que facilita la decisión.
          </p>
          <p class="mt-4 text-base leading-8 text-slate-600">
            Ya sea una escapada en pareja, un viaje con amigos o en familia, Hostería Agoyán ofrece el espacio, la comodidad
            y el entorno natural para desconectarte de verdad. Reserva
            directamente por WhatsApp — sin cargos ocultos.
          </p>
          <a
            href={waUrl}
            target="_blank"
            rel="noopener"
            class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition hover:text-emerald-500"
          >
            Consultar disponibilidad
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="relative pb-10" data-reveal>
          <img
            src={promo.gallery[0].src}
            alt="Fin de semana en Hostería Agoyán"
            class="w-full rounded-[2rem] object-cover shadow-[0_20px_50px_rgba(0,0,0,0.10)]"
            loading="lazy"
          />
          <div class="absolute -bottom-2 left-6 max-w-[280px] rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-[0_16px_40px_rgba(0,0,0,0.10)]">
            <div class="flex items-center gap-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-600">
                  <rect x="4" y="5" width="16" height="15" rx="2"/>
                  <path d="M8 3v4M16 3v4M4 10h16"/>
                </svg>
              </span>
              <div class="text-sm font-semibold text-slate-900">Tarifa especial Dom – Jue</div>
            </div>
            <p class="mt-2 text-xs leading-6 text-slate-500">
              Piscina, sauna, áreas verdes y acceso completo al bienestar — a un precio pensado para el fin de semana.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ QUÉ INCLUYE ═══════════════════════════════════════ -->
  <section id="incluye" class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">QUÉ INCLUYE</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
          Todo lo necesario para un fin de semana especial
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
        {promo.includes.map((item) => (
          <div
            class="group flex items-start gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)]"
            data-reveal
          >
            <span class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 transition-colors duration-300 group-hover:bg-emerald-200">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-600">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
            </span>
            <p class="text-sm leading-7 text-slate-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ GALERÍA ═══════════════════════════════════════ -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">GALERÍA</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
          El escenario ideal para una escapada de relax entre semana
        </h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <!-- imagen grande — masonry -->
        <div class="group relative overflow-hidden rounded-3xl lg:col-span-2 lg:row-span-2" data-reveal>
          <img
            src={promo.gallery[0].src}
            alt={promo.gallery[0].alt}
            class="h-[280px] w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform] lg:h-full lg:min-h-[460px]"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          <span class="absolute bottom-4 left-4 right-4 truncate rounded-xl bg-white/90 px-3.5 py-1.5 text-xs font-semibold text-slate-800 opacity-0 backdrop-blur transition-opacity duration-300 group-hover:opacity-100">
            {promo.gallery[0].alt}
          </span>
        </div>
        <!-- imágenes pequeñas -->
        {promo.gallery.slice(1).map((img) => (
          <div class="group relative overflow-hidden rounded-3xl" data-reveal>
            <img
              src={img.src}
              alt={img.alt}
              class="h-[210px] w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <span class="absolute bottom-3 left-3 right-3 truncate rounded-xl bg-white/90 px-3 py-1 text-xs font-semibold text-slate-800 opacity-0 backdrop-blur transition-opacity duration-300 group-hover:opacity-100">
              {img.alt}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ EXTRAS + CONDICIONES ═══════════════════════════════════════ -->
  <section class="bg-slate-50 py-20">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">

      <!-- extras -->
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_8px_28px_rgba(0,0,0,0.05)]" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">ADICIONALES</p>
        <h3 class="mt-3 font-hero text-3xl text-slate-900">Complementa tu promoción</h3>
        <ul class="mt-6 space-y-4">
          {promo.extras.map((item) => (
            <li class="flex items-start gap-3.5">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-teal-100">
                <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" class="text-teal-600">
                  <path d="M12 5v14M5 12h14"/>
                </svg>
              </span>
              <span class="text-sm leading-7 text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- condiciones -->
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_8px_28px_rgba(0,0,0,0.05)]" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-slate-500">CONDICIONES</p>
        <h3 class="mt-3 font-hero text-3xl text-slate-900">Antes de reservar</h3>
        <ul class="mt-6 space-y-4">
          {promo.conditions.map((item) => (
            <li class="flex items-start gap-3.5">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-slate-100">
                <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-500">
                  <path d="M12 8v4M12 16h.01"/>
                  <circle cx="12" cy="12" r="10"/>
                </svg>
              </span>
              <span class="text-sm leading-7 text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════ DARK CTA ═══════════════════════════════════════ -->
  <section class="cta-section relative -mx-4 overflow-hidden py-28 sm:-mx-6 sm:py-36 lg:-mx-8">
    <!-- glow orbs -->
    <div class="pointer-events-none absolute -left-32 -top-32 h-[480px] w-[480px] rounded-full bg-emerald-400/20 blur-[96px]"></div>
    <div class="pointer-events-none absolute -right-32 bottom-0 h-[440px] w-[440px] rounded-full bg-teal-300/15 blur-[80px]"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-emerald-500/10 blur-[100px]"></div>
    <div class="cta-grid pointer-events-none absolute inset-0 opacity-[0.06]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-300/40 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal-300/30 to-transparent"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <div class="mb-8 flex justify-center">
        <div class="cta-badge inline-flex h-16 w-16 items-center justify-center rounded-2xl">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="4" y="5" width="16" height="15" rx="2"/>
            <path d="M8 3v4M16 3v4M4 10h16"/>
          </svg>
        </div>
      </div>

      <p class="font-menu text-sm tracking-[0.2em] text-emerald-300">
        RESERVA TU PROMOCIÓN DE FIN DE SEMANA
      </p>
      <h2 class="mt-5 font-hero text-4xl leading-[1.04] text-white sm:text-5xl lg:text-6xl">
        Tu mejor fin de semana<br />empieza en Hostería Agoyán
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-white/75 sm:text-lg">
        Piscina, zona de bienestar, áreas verdes y la belleza natural de Baños
        de Agua Santa — todo a una tarifa especial de fin de semana. Reserva
        directamente por WhatsApp y confirmamos tu reserva de inmediato.
      </p>

      <!-- pills -->
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        {[
          { icon: "📅", label: "Tarifa especial Vie – Dom" },
          { icon: "🏊", label: "Piscina y bienestar" },
          { icon: "🌿", label: "Rodeado de naturaleza" },
        ].map((f) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-5 py-2 text-sm text-white/85 backdrop-blur">
            <span aria-hidden="true">{f.icon}</span>{f.label}
          </span>
        ))}
      </div>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="cta-wa-btn inline-flex min-w-[230px] items-center justify-center gap-2.5 rounded-2xl bg-white px-8 py-4 text-sm font-bold text-emerald-700"
        >
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
