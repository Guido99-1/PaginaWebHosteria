---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { SITE } from "../../../../config/site";

const facility = {
  title: "Salones de Eventos",
  subtitle:
    "Espacios diseñados para reuniones, celebraciones y ocasiones especiales con un ambiente cómodo, funcional y una atención personalizada.",
  heroImage: "/imagenes/instalaciones/Comedor2.jpg",
  gallery: [
    { src: "/imagenes/instalaciones/Comedor3.jpg", alt: "Salón principal de eventos" },
    { src: "/imagenes/instalaciones/Comedor2.jpg",     alt: "Montaje para eventos" },
    { src: "/imagenes/instalaciones/Comedor.jpg",     alt: "Área de banquetes" },
    { src: "/imagenes/instalaciones/Comedor6.jpg",     alt: "Decoración para celebraciones" },
  ],
  features: [
    "Espacios amplios y funcionales para eventos",
    "Atención personalizada en cada celebración",
    "Ideal para reuniones empresariales y sociales",
    "Capacidad para grupos medianos y grandes",
    "Coordinación de montaje y decoración",
    "Menús especiales disponibles bajo solicitud",
  ],
  amenities: [
    {
      name: "Eventos Sociales",
      description:
        "El espacio perfecto para cumpleaños, aniversarios, reuniones familiares y toda clase de celebraciones especiales.",
      icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" width="26" height="26"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    },
    {
      name: "Reuniones de Empresa",
      description:
        "Ambientes equipados y funcionales para sesiones de trabajo, capacitaciones, presentaciones y conferencias.",
      icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" width="26" height="26"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    },
    {
      name: "Bodas y Recepciones",
      description:
        "Salones con ambiente y capacidad para recibir ceremonias y recepciones con el detalle que cada pareja merece.",
      icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" width="26" height="26"><path d="M12 2l2.09 6.26L21 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
    },
    {
      name: "Atención Personalizada",
      description:
        "Nuestro equipo te acompaña en la planificación de cada detalle para que tu evento sea exactamente como lo imaginaste.",
      icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" width="26" height="26"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    },
  ],
  stats: [
    { value: "+",    label: "tipos de eventos" },
    { value: "365",  label: "días disponible" },
    { value: "100%", label: "atención personalizada" },
    { value: "∞",    label: "celebraciones únicas" },
  ],
};

const waText = `Hola, quiero información sobre los ${facility.title} en ${SITE.name}.`;
const waUrl  = `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout
  lang="es"
  title={`${facility.title} | ${SITE.name}`}
  description={facility.subtitle}
>

  <!-- ══ HERO ══════════════════════════════════════════════ -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative h-[78vh] min-h-[560px] overflow-hidden">
      <img src={facility.heroImage} alt={facility.title}
        class="absolute inset-0 h-full w-full object-cover object-center" loading="eager" fetchpriority="high"/>
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/25 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-black/10"></div>
      <div class="relative z-10 mx-auto flex h-full max-w-7xl flex-col justify-end px-4 pb-16 pt-28 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-reveal>
          <div class="mb-4 flex items-center gap-2 font-menu text-xs tracking-[0.16em] text-white/55">
            <a href="/es/instalaciones/" class="transition hover:text-white/90">INSTALACIONES</a>
            <span>/</span>
            <span class="text-emerald-300">SALONES DE EVENTOS</span>
          </div>
          <h1 class="font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">{facility.title}</h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-white/82 sm:text-lg">{facility.subtitle}</p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href={waUrl} target="_blank" rel="noopener"
              class="hero-wa-btn inline-flex items-center justify-center gap-2.5 rounded-2xl px-7 py-3.5 text-sm font-bold text-white">
              <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
              Consultar por WhatsApp
            </a>
            <a href="/es/instalaciones/"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/30 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
              Volver a instalaciones
            </a>
          </div>
        </div>
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/50">
          <span class="font-menu text-[10px] tracking-widest">EXPLORAR</span>
          <svg class="scroll-arrow" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ STATS ═════════════════════════════════════════════ -->
  <section class="border-b border-slate-100 bg-white py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-slate-100 lg:grid-cols-4">
        {facility.stats.map((s) => (
          <div class="bg-white px-6 py-7 text-center">
            <p class="font-hero text-4xl text-emerald-600 sm:text-5xl">{s.value}</p>
            <p class="mt-1.5 text-sm leading-snug text-slate-500">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ AMENIDADES ════════════════════════════════════════ -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">CELEBRACIONES Y REUNIONES</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Todo lo que encontrarás</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-500">
          Espacios versátiles y un equipo comprometido para hacer de cada evento una experiencia única e inolvidable.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {facility.amenities.map((item, i) => (
          <div class="amenity-card group relative overflow-hidden rounded-3xl border border-slate-100 bg-white p-7 shadow-[0_4px_20px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_14px_36px_rgba(0,0,0,0.10)]" data-reveal>
            <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-gradient-to-r from-emerald-400 to-teal-400 transition-transform duration-500 group-hover:scale-x-100 [will-change:transform]"></div>
            <span class="select-none font-hero text-5xl font-bold leading-none text-slate-100">{String(i + 1).padStart(2, "0")}</span>
            <div class="amenity-icon mt-3 inline-flex h-12 w-12 items-center justify-center rounded-2xl text-emerald-600 transition-colors duration-300">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="mt-4 font-hero text-xl text-slate-900">{item.name}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-500">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ INFO + FEATURES ══════════════════════════════════ -->
  <section class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-[1fr_0.85fr] lg:gap-16 lg:px-8">
      <div data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">SOBRE EL ESPACIO</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Tu evento merece el mejor escenario</h2>
        <p class="mt-5 text-base leading-8 text-slate-600">
          Los Salones de Eventos de Hostería Agoyán son el espacio ideal para hacer realidad celebraciones y reuniones de todo tipo. Con ambientes amplios, funcionales y un entorno natural único, cada evento se convierte en una experiencia especial.
        </p>
        <p class="mt-4 text-base leading-8 text-slate-600">
          Nuestro equipo te acompaña en la coordinación de cada detalle, desde el montaje hasta el menú, para que solo te preocupes por disfrutar junto a tus invitados.
        </p>
        <a href={waUrl} target="_blank" rel="noopener"
          class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition hover:text-emerald-500">
          Consultar disponibilidad
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_10px_30px_rgba(0,0,0,0.06)]" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">QUÉ INCLUYE</p>
        <ul class="mt-6 space-y-4">
          {facility.features.map((item) => (
            <li class="flex items-start gap-3.5">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100">
                <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-600"><path d="M20 6L9 17l-5-5"/></svg>
              </span>
              <span class="text-sm leading-7 text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
        <a href={waUrl} target="_blank" rel="noopener"
          class="mt-8 inline-flex w-full items-center justify-center gap-2.5 rounded-2xl bg-emerald-500 px-6 py-3.5 text-sm font-bold text-white transition hover:bg-emerald-400">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          Consultar para mi evento
        </a>
      </div>
    </div>
  </section>

  <!-- ══ GALERÍA ══════════════════════════════════════════ -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">GALERÍA</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Conoce nuestros salones</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <div class="gallery-item group relative overflow-hidden rounded-3xl lg:col-span-2 lg:row-span-2" data-reveal>
          <img src={facility.gallery[0].src} alt={facility.gallery[0].alt}
            class="h-[300px] w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform] lg:h-full lg:min-h-[480px]" loading="lazy"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          <span class="absolute bottom-4 left-4 rounded-full bg-white/90 px-3.5 py-1.5 text-xs font-semibold text-slate-800 opacity-0 backdrop-blur transition-opacity duration-300 group-hover:opacity-100">{facility.gallery[0].alt}</span>
        </div>
        {facility.gallery.slice(1).map((img) => (
          <div class="gallery-item group relative overflow-hidden rounded-3xl" data-reveal>
            <img src={img.src} alt={img.alt}
              class="h-[220px] w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform]" loading="lazy"/>
            <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <span class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-slate-800 opacity-0 backdrop-blur transition-opacity duration-300 group-hover:opacity-100">{img.alt}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ CTA FINAL ════════════════════════════════════════ -->
  <section class="cta-section relative -mx-4 overflow-hidden py-28 sm:-mx-6 sm:py-36 lg:-mx-8">
    <div class="pointer-events-none absolute -left-32 -top-32 h-[480px] w-[480px] rounded-full bg-emerald-400/20 blur-[96px]"></div>
    <div class="pointer-events-none absolute -right-32 bottom-0 h-[440px] w-[440px] rounded-full bg-teal-300/15 blur-[80px]"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-emerald-500/10 blur-[100px]"></div>
    <div class="cta-grid pointer-events-none absolute inset-0 opacity-[0.06]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-300/40 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal-300/30 to-transparent"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <div class="mb-8 flex justify-center">
        <div class="cta-badge inline-flex h-16 w-16 items-center justify-center rounded-2xl">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
            <rect x="4" y="5" width="16" height="15" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/>
          </svg>
        </div>
      </div>
      <p class="font-menu text-sm tracking-[0.2em] text-emerald-300">RESERVA TU EVENTO</p>
      <h2 class="mt-5 font-hero text-4xl leading-[1.04] text-white sm:text-5xl lg:text-6xl">
        Haz de tu evento<br />algo inolvidable
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-white/75 sm:text-lg">
        Reuniones, celebraciones y eventos especiales en un entorno único. Contáctanos y coordinamos todos los detalles contigo.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={waUrl} target="_blank" rel="noopener"
          class="cta-wa-btn inline-flex min-w-[220px] items-center justify-center gap-2.5 rounded-2xl bg-white px-8 py-4 text-sm font-bold text-emerald-700">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          Consultar por WhatsApp
        </a>
        <a href="/es/contacto/"
          class="inline-flex min-w-[180px] items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-sm font-semibold text-white backdrop-blur transition hover:border-white/40 hover:bg-white/18">
          Ir a contacto
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-wa-btn { background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 8px 24px rgba(16,185,129,0.38); transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease; }
  .hero-wa-btn:hover { transform: translateY(-2px); filter: brightness(1.07); box-shadow: 0 14px 34px rgba(16,185,129,0.48); }
  .scroll-arrow { animation: bounce-arr 1.8s ease-in-out infinite; }
  @keyframes bounce-arr { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(6px); } }
  .amenity-icon { background: rgba(16,185,129,0.09); }
  .amenity-card:hover .amenity-icon { background: rgba(16,185,129,0.16); }
  .cta-section { background: radial-gradient(ellipse at 20% 50%, rgba(16,185,129,0.18) 0%, transparent 50%), radial-gradient(ellipse at 80% 20%, rgba(20,184,166,0.14) 0%, transparent 45%), linear-gradient(160deg, #0d2218 0%, #0f2d22 30%, #0b2320 60%, #071a17 100%); }
  .cta-grid { background-image: linear-gradient(rgba(255,255,255,0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.07) 1px, transparent 1px); background-size: 48px 48px; mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%); }
