---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";

const heroSlides = [
  "/imagenes/instalaciones/hidromasaje.jpg",
  "/imagenes/instalaciones/Piscina3.jpg",
  "/imagenes/instalaciones/Comedor.jpg",
  "/imagenes/instalaciones/Sala.jpg",
];

const quickNav = [
  { label: "Zona Húmeda",    href: "/es/instalaciones/areaHumeda/",    icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 15c1.2 0 1.8 1 3 1s1.8-1 3-1 1.8 1 3 1 1.8-1 3-1 1.8 1 3 1 1.8-1 3-1"/><path d="M7 10a3 3 0 1 1 6 0v1H7v-1Z"/></svg>` },
  { label: "Restaurante",    href: "/es/instalaciones/restaurante/",   icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 11l1-6h16l1 6"/><path d="M3 11h18v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-8Z"/></svg>` },
  { label: "Áreas Verdes",   href: "/es/instalaciones/areasVerdes/",   icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22V12M12 12C12 7 7 4 3 6M12 12C12 7 17 4 21 6"/></svg>` },
  { label: "Salón de Juegos",href: "/es/instalaciones/salonDeJuegos/", icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M8 12h2m1-1v2M16 11h2"/></svg>` },
  { label: "Bar",            href: "/es/instalaciones/discoteca/",     icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 2l4 10 4-10"/><path d="M4 10h16M9 22h6M12 12v10"/></svg>` },
  { label: "Parqueadero",    href: "#instalaciones",                   icon: `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="22" height="14" rx="2"/><path d="M6 21h12M9 17v4M15 17v4"/></svg>` },
];

const featuredExperiences = [
  {
    kicker: "Gastronomía",
    title: "Restaurante y momentos para compartir",
    description:
      "Un espacio acogedor para desayunos, almuerzos, cenas y momentos especiales en un ambiente cálido y agradable.",
    imageMain: "/imagenes/instalaciones/Comedor3.jpg",
    imageTop: "/imagenes/instalaciones/Comedor4.jpg",
    imageBottom: "/imagenes/instalaciones/Comedor5.jpg",
    points: [
      "Desayunos y platos especiales",
      "Ambiente acogedor y cálido",
      "Ideal para compartir en grupo",
    ],
    href: "/es/instalaciones/restaurante/",
    number: "01",
  },
  {
    kicker: "Naturaleza",
    title: "Áreas verdes y descanso al aire libre",
    description:
      "Espacios abiertos, tranquilidad y rincones naturales para caminar, respirar y desconectarte del ritmo diario.",
    imageMain: "/imagenes/instalaciones/Cascada2.jpeg",
    imageTop: "/imagenes/instalaciones/AreasVerdes.jpeg",
    imageBottom: "/imagenes/instalaciones/AreasVerdes4.png",
    points: [
      "Entorno natural privilegiado",
      "Áreas de descanso al aire libre",
      "Ambiente tranquilo y relajante",
    ],
    href: "/es/instalaciones/areasVerdes/",
    number: "02",
  },
];

const facilities = [
  {
    title: "Área Húmeda",
    description: "Piscina, sauna, turco e hidromasaje para una experiencia completa de relajación.",
    image: "/imagenes/instalaciones/Piscina.jpeg",
    href: "/es/instalaciones/areaHumeda/",
    badge: "Bienestar",
    number: "01",
  },
  {
    title: "Restaurante",
    description: "Un ambiente ideal para disfrutar buena comida y momentos especiales.",
    image: "/imagenes/instalaciones/Comedor6.jpg",
    href: "/es/instalaciones/restaurante/",
    badge: "Gastronomía",
    number: "02",
  },
  {
    title: "Bar",
    description: "Un espacio para compartir bebidas y complementar tu experiencia en la hostería.",
    image: "/imagenes/instalaciones/Bar.png",
    href: "/es/instalaciones/discoteca/",
    badge: "Ambiente",
    number: "03",
  },
  {
    title: "Áreas Verdes",
    description: "Naturaleza, paisaje y espacios abiertos para disfrutar con calma.",
    image: "/imagenes/instalaciones/AreasVerdes2.jpeg",
    href: "/es/instalaciones/areasVerdes/",
    badge: "Naturaleza",
    number: "04",
  },
  {
    title: "Salón de Juegos",
    description: "Diversión y entretenimiento para compartir en pareja, familia o con amigos.",
    image: "/imagenes/instalaciones/SalonJuegos.jpeg",
    href: "/es/instalaciones/salonDeJuegos/",
    badge: "Diversión",
    number: "05",
  },
  {
    title: "Parqueadero",
    description: "Comodidad y seguridad para tu vehículo durante toda tu visita o estadía.",
    image: "/imagenes/instalaciones/Garage3.jpg",
    href: undefined,
    badge: "Confort",
    number: "06",
  },
];

const waText = `Hola, quiero información sobre las instalaciones de ${SITE.name}.`;
const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout
  lang="es"
  title={`Instalaciones | ${SITE.name}`}
  description="Espacios diseñados para descansar, disfrutar y reconectar en Hostería Agoyán."
>

  <!-- ── Hero con texto overlay ─────────────────────────── -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="facility-hero relative h-[78vh] min-h-[560px] overflow-hidden rounded-b-[2.5rem] bg-slate-950">

      <!-- Slides -->
      <div class="facility-hero-track absolute inset-0">
        {heroSlides.map((img, i) => (
          <div
            class={`facility-hero-slide absolute inset-0 ${i === 0 ? "is-active" : ""}`}
            style={`background-image:url('${img}')`}
          />
        ))}
      </div>

      <!-- Overlays -->
      <div class="absolute inset-0 bg-black/28"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-slate-950/60 via-slate-950/15 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/15 to-transparent"></div>

      <!-- Contenido text overlay -->
      <div class="relative z-10 mx-auto flex h-full max-w-7xl flex-col justify-between px-4 pb-12 pt-28 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-reveal>
          <p class="font-menu text-sm tracking-[0.18em] text-emerald-300 uppercase">
            INSTALACIONES AGOYÁN
          </p>
          <h1 class="mt-4 font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">
            Espacios para<br class="hidden sm:block" /> disfrutar y reconectar
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-white/80 sm:text-lg">
            Descubre ambientes pensados para el bienestar, la gastronomía y la
            naturaleza en Hostería Agoyán.
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href="#instalaciones"
              class="hero-primary inline-flex items-center justify-center gap-2 rounded-2xl px-7 py-3.5 text-sm font-semibold text-white"
            >
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="1.8"/>
                <path d="M9 22V12h6v10" stroke="currentColor" stroke-width="1.8"/>
              </svg>
              Explorar instalaciones
            </a>
            <a
              href={waUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center rounded-2xl border border-white/30 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/20"
            >
              Consultar por WhatsApp
            </a>
          </div>
        </div>

        <!-- Dots + scroll indicator -->
        <div class="flex items-center justify-between">
          <div class="flex gap-2" aria-hidden="true">
            {heroSlides.map((_, i) => (
              <span class={`facility-dot ${i === 0 ? "is-active" : ""}`} data-dot={i} />
            ))}
          </div>

          <div class="scroll-arrow flex h-10 w-10 items-center justify-center rounded-full border border-white/25 bg-white/10 text-white backdrop-blur" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Intro + quick nav ──────────────────────────────── -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <p class="font-menu text-sm tracking-[0.14em] text-emerald-600 uppercase">
        INSTALACIONES AGOYÁN
      </p>
      <h2 class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Espacios que convierten tu visita en una experiencia inolvidable
      </h2>
      <p class="mx-auto mt-5 max-w-3xl text-base leading-8 text-slate-600 sm:text-lg">
        Descubre ambientes pensados para el descanso, la naturaleza, la gastronomía y el
        bienestar, con un diseño acogedor que te invita a disfrutar cada momento.
      </p>

      <!-- Quick nav chips -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        {quickNav.map((item) => (
          <a
            href={item.href}
            class="qnav-chip inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:-translate-y-0.5 hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700"
          >
            <span class="text-emerald-500" set:html={item.icon} />
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Zona húmeda destacada ─────────────────────────── -->
  <section class="bg-white pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" data-reveal>
      <div class="overflow-hidden rounded-[2.5rem] border border-slate-200 bg-slate-50 shadow-[0_20px_55px_rgba(0,0,0,0.08)]">
        <div class="grid lg:grid-cols-[1.15fr_0.85fr]">

          <!-- Imagen -->
          <div class="relative min-h-[380px] overflow-hidden lg:min-h-[560px]">
            <img
              src="/imagenes/instalaciones/Piscina.jpeg"
              alt="Zona húmeda Hostería Agoyán"
              class="absolute inset-0 h-full w-full object-cover transition duration-700 hover:scale-[1.03]"
              loading="eager" fetchpriority="high"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-black/20 via-black/5 to-transparent"></div>
            <!-- Badge flotante -->
            <div class="absolute left-5 top-5">
              <span class="rounded-full bg-white/95 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-slate-800 shadow-sm">
                Experiencia destacada
              </span>
            </div>
          </div>

          <!-- Contenido -->
          <div class="p-8 sm:p-10 lg:p-14">
            <p class="font-menu text-sm tracking-[0.14em] text-emerald-600 uppercase">
              BIENESTAR
            </p>

            <h2 class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl">
              Zona húmeda, descanso y bienestar en un solo lugar
            </h2>

            <p class="mt-5 text-base leading-8 text-slate-600">
              Piscina, sauna, turco e hidromasaje se combinan para crear una experiencia
              premium de relajación, ideal para parejas, familias y quienes buscan desconectarse.
            </p>

            <!-- Info cards con iconos -->
            <div class="mt-8 grid gap-4 sm:grid-cols-2">
              <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-[0_8px_20px_rgba(0,0,0,0.04)]">
                <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-50 text-emerald-500">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 15c1.2 0 1.8 1 3 1s1.8-1 3-1 1.8 1 3 1 1.8-1 3-1 1.8 1 3 1 1.8-1 3-1"/><path d="M7 10a3 3 0 1 1 6 0v1H7v-1Z"/></svg>
                </div>
                <div class="text-xs uppercase tracking-[0.08em] text-slate-400">Incluye</div>
                <div class="mt-1 text-sm font-semibold text-slate-900">
                  Piscina, sauna, turco e hidromasaje
                </div>
              </div>

              <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-[0_8px_20px_rgba(0,0,0,0.04)]">
                <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-sky-50 text-sky-500">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="text-xs uppercase tracking-[0.08em] text-slate-400">Ideal para</div>
                <div class="mt-1 text-sm font-semibold text-slate-900">
                  Descanso y bienestar
                </div>
              </div>
            </div>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a
                href="/es/instalaciones/areaHumeda/"
                class="wet-btn inline-flex items-center justify-center gap-2 rounded-2xl px-7 py-3.5 text-sm font-semibold text-white"
              >
                <svg viewBox="0 0 24 24" width="15" height="15" fill="none" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Ver área húmeda
              </a>
              <a
                href={waUrl}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-7 py-3.5 text-sm font-semibold text-slate-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700"
              >
                Consultar por WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Experiencias destacadas ───────────────────────── -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-14 max-w-3xl text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.14em] text-emerald-600 uppercase">
          EXPERIENCIAS DESTACADAS
        </p>
        <h2 class="mt-4 font-hero text-4xl text-slate-900 sm:text-5xl">
          Ambientes con personalidad propia
        </h2>
      </div>

      <div class="space-y-24">
        {featuredExperiences.map((item, index) => (
          <div class="grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]" data-reveal>

            <!-- Imágenes -->
            <div class={index % 2 === 1 ? "lg:order-2" : ""}>
              <div class="grid gap-5 sm:grid-cols-[1.15fr_0.85fr]">
                <div class="exp-img-wrap overflow-hidden rounded-[2rem] shadow-[0_18px_45px_rgba(0,0,0,0.08)]">
                  <img
                    src={item.imageMain}
                    alt={item.title}
                    class="h-full min-h-[440px] w-full object-cover transition duration-700 hover:scale-[1.04]"
                    loading="lazy"
                  />
                </div>
                <div class="grid gap-5">
                  <div class="overflow-hidden rounded-[1.75rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)]">
                    <img
                      src={item.imageTop}
                      alt={`${item.title} detalle 1`}
                      class="h-[210px] w-full object-cover transition duration-700 hover:scale-[1.04]"
                      loading="lazy"
                    />
                  </div>
                  <div class="overflow-hidden rounded-[1.75rem] shadow-[0_14px_35px_rgba(0,0,0,0.08)]">
                    <img
                      src={item.imageBottom}
                      alt={`${item.title} detalle 2`}
                      class="h-[210px] w-full object-cover transition duration-700 hover:scale-[1.04]"
                      loading="lazy"
                    />
                  </div>
                </div>
              </div>
            </div>

            <!-- Texto -->
            <div class={index % 2 === 1 ? "lg:order-1" : ""}>
              <!-- Número editorial -->
              <span class="font-hero text-8xl font-bold leading-none text-slate-100 select-none" aria-hidden="true">
                {item.number}
              </span>

              <p class="mt-1 font-menu text-sm tracking-[0.14em] text-emerald-600 uppercase">
                {item.kicker}
              </p>
              <h3 class="mt-3 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl">
                {item.title}
              </h3>
              <p class="mt-5 text-base leading-8 text-slate-600">
                {item.description}
              </p>

              <!-- Puntos con checkmarks SVG -->
              <ul class="mt-8 space-y-3">
                {item.points.map((point) => (
                  <li class="flex items-center gap-3 text-slate-700">
                    <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" aria-hidden="true">
                        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <span class="text-base">{point}</span>
                  </li>
                ))}
              </ul>

              <!-- CTA pill -->
              <div class="mt-8">
                <a
                  href={item.href}
                  class="exp-cta-pill inline-flex items-center gap-2.5 rounded-xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-800 transition hover:border-emerald-400 hover:bg-emerald-50 hover:text-emerald-700"
                >
                  Ver espacio completo
                  <svg viewBox="0 0 24 24" width="15" height="15" fill="none" aria-hidden="true">
                    <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Grid completo de instalaciones ───────────────── -->
  <section id="instalaciones" class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-14 max-w-3xl text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.14em] text-emerald-600 uppercase">
          TODAS LAS INSTALACIONES
        </p>
        <h2 class="mt-4 font-hero text-4xl text-slate-900 sm:text-5xl">
          Cada espacio pensado para disfrutar mejor tu visita
        </h2>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
        {facilities.map((item) => {
          const Tag = item.href ? "a" : "div";
          return (
            <article class="fac-card group relative overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_12px_35px_rgba(0,0,0,0.06)]" data-reveal>

              <!-- Línea de acento superior -->
              <div class="fac-accent-line" aria-hidden="true"></div>

              <Tag href={item.href} class="block">
                <!-- Imagen -->
                <div class="relative h-72 overflow-hidden">
                  <img
                    src={item.image}
                    alt={item.title}
                    class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.05] [will-change:transform]"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/8 to-transparent"></div>

                  <!-- Badge -->
                  <div class="absolute left-5 top-5">
                    <span class="rounded-full bg-white/95 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-slate-800 shadow-sm">
                      {item.badge}
                    </span>
                  </div>
                </div>

                <!-- Body -->
                <div class="relative p-7">
                  <!-- Número editorial -->
                  <span class="pointer-events-none absolute right-6 top-4 select-none font-hero text-7xl font-bold leading-none text-slate-100 transition duration-300 group-hover:text-emerald-50" aria-hidden="true">
                    {item.number}
                  </span>

                  <h3 class="relative font-hero text-2xl text-slate-900">{item.title}</h3>
                  <p class="relative mt-3 text-sm leading-7 text-slate-600">{item.description}</p>

                  {item.href && (
                    <div class="relative mt-6">
                      <span class="fac-cta-pill inline-flex items-center gap-2 rounded-xl border px-5 py-2.5 text-sm font-semibold transition">
                        Explorar espacio
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" aria-hidden="true">
                          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    </div>
                  )}
                </div>
              </Tag>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ── CTA final full-width ──────────────────────────── -->
  <section class="cta-inst-section relative overflow-hidden py-28 sm:py-32">

    <!-- Decoración -->
    <div class="pointer-events-none absolute -left-32 -top-32 h-[480px] w-[480px] rounded-full bg-emerald-400/18 blur-[90px]"></div>
    <div class="pointer-events-none absolute -right-32 bottom-0 h-[440px] w-[440px] rounded-full bg-teal-300/14 blur-[75px]"></div>
    <div class="cta-inst-grid pointer-events-none absolute inset-0 opacity-[0.055]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-300/35 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal-300/25 to-transparent"></div>

    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8" data-reveal>

      <!-- Badge icono -->
      <div class="mb-7 flex justify-center">
