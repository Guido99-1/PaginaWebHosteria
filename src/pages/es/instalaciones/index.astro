<style>
  /* ── Hero slides ── */
  .facility-hero-slide {
    background-position: center;
    background-size: cover;
    opacity: 0;
    transform: scale(1.06);
    transition: opacity 1.2s ease, transform 7s ease;
  }
  .facility-hero-slide.is-active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Dots ── */
  .facility-dot {
    height: 8px;
    width: 8px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: all 0.35s ease;
  }
  .facility-dot.is-active {
    width: 28px;
    background: white;
  }

  /* ── Hero botón principal ── */
  .hero-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 14px 30px rgba(16, 185, 129, 0.28);
    transition: transform 0.25s ease, filter 0.25s ease, box-shadow 0.25s ease;
  }
  .hero-primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 18px 36px rgba(16, 185, 129, 0.34);
  }

  /* ── Scroll indicator ── */
  .scroll-arrow {
    animation: scrollBounce 2s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 0.7; }
    50%       { transform: translateY(6px); opacity: 1; }
  }

  /* ── Quick nav chips ── */
  .qnav-chip {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }
  .qnav-chip :global(svg) { flex-shrink: 0; }

  /* ── Zona húmeda botón ── */
  .wet-btn {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 12px 28px rgba(16, 185, 129, 0.24);
    transition: transform 0.25s ease, filter 0.25s ease, box-shadow 0.25s ease;
  }
  .wet-btn:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow: 0 16px 32px rgba(16, 185, 129, 0.3);
  }

  /* ── Facility card ── */
  .fac-card {
    transition: transform 0.32s ease, box-shadow 0.32s ease;
  }
  .fac-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 50px rgba(0, 0, 0, 0.11);
  }

  /* Línea de acento superior */
  .fac-accent-line {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #10b981, #0ea5e9);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }
  .fac-card:hover .fac-accent-line {
    transform: scaleX(1);
  }

  /* CTA pill en cards */
  .fac-cta-pill {
    border-color: #e2e8f0;
    color: #10b981;
    background: transparent;
  }
  .fac-card:hover .fac-cta-pill {
    border-color: #10b981;
    background: #f0fdf4;
    color: #059669;
  }

  /* ── CTA final ── */
  .cta-inst-section {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(16, 185, 129, 0.17) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(20, 184, 166, 0.13) 0%, transparent 45%),
      linear-gradient(160deg, #0d2218 0%, #0f2d22 30%, #0b2320 60%, #071a17 100%);
  }
  .cta-inst-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.07) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }
  .cta-inst-primary {
    box-shadow: 0 16px 40px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
  }
  .cta-inst-primary:hover {
    transform: translateY(-2px);
    filter: brightness(1.03);
    box-shadow: 0 22px 48px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.1);
  }
</style>

<script>
  (() => {
    const hero = document.querySelector(".facility-hero");
    if (!hero) return;

    const slides = Array.from(hero.querySelectorAll<HTMLElement>(".facility-hero-slide"));
    const dots   = Array.from(hero.querySelectorAll<HTMLElement>(".facility-dot"));
    if (!slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    const setActive = (index: number) => {
      slides.forEach((s, i) => s.classList.toggle("is-active", i === index));
      dots.forEach((d, i)   => d.classList.toggle("is-active", i === index));
    };

    const advance = () => {
      current = (current + 1) % slides.length;
      setActive(current);
    };

    const reset = () => {
      clearInterval(timer);
      timer = setInterval(advance, 4500);
    };

    setActive(current);
    reset();

    // Click en dots para navegar
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        current = i;
        setActive(current);
        reset();
      });
    });
  })();
</script>
