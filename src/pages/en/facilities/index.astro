---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";

const heroImage = "/imagenes/instalaciones/AreasVerdes3.jpg";

const facilities = [
  {
    title: "Wet Area",
    emoji: "🏊",
    badge: "Wellness",
    description:
      "Outdoor pool, sauna, steam room and hydromassage for a complete relaxation experience surrounded by cloud forest.",
    image: "/imagenes/instalaciones/FullDay2.jpg",
    href: "/en/facilities/areaHumedaEN/",
    pills: ["🏊 Outdoor pool", "♨️ Sauna & steam", "💆 Hydromassage"],
  },
  {
    title: "Restaurant",
    emoji: "🍽️",
    badge: "Gastronomy",
    description:
      "A welcoming space with buffet breakfasts, à la carte lunches and regional cuisine with panoramic mountain views.",
    image: "/imagenes/instalaciones/Familia.jpg",
    href: "/en/facilities/restauranteEN/",
    pills: ["🍳 Buffet breakfast", "🌿 Terrace dining", "🍽️ Regional cuisine"],
  },
  {
    title: "Green Spaces",
    emoji: "🌿",
    badge: "Nature",
    description:
      "Tropical gardens, natural trails and open areas immersed in the Amazon cloud forest of the Ecuadorian Andes.",
    image: "/imagenes/instalaciones/AreasVerdes2.jpeg",
    href: "/en/facilities/areaVerdeEn/",
    pills: ["🌿 Tropical gardens", "🐦 Birdwatching", "📸 Photography"],
  },
  {
    title: "Game Room",
    emoji: "🎱",
    badge: "Fun",
    description:
      "Billiards, ping pong, video games and more — fun and entertainment for all ages, couples and families.",
    image: "/imagenes/instalaciones/FullDay.jpg",
    href: "/en/facilities/salonDeJuegosEN/",
    pills: ["🎱 Billiards", "🏓 Ping pong", "👨‍👩‍👧 Family fun"],
  },
  {
    title: "Event Halls",
    emoji: "🎊",
    badge: "Events",
    description:
      "Versatile spaces for weddings, corporate events, birthdays and celebrations — full AV equipment included.",
    image: "/imagenes/instalaciones/ExteriorSuites2.jpg",
    href: "/en/facilities/salonesEventosEN/",
    pills: ["💍 Weddings", "🏢 Corporate", "🎂 Celebrations"],
  },
  {
    title: "Disco",
    emoji: "🎵",
    badge: "Entertainment",
    description:
      "A lively nightlife space with professional DJ, full bar service and LED lighting — perfect for private events.",
    image: "/imagenes/instalaciones/Pareja2.jpg",
    href: "/en/facilities/discotecaEN/",
    pills: ["🎵 Live DJ", "🍹 Full bar", "🎊 Private events"],
  },
];

const heroStats = [
  { emoji: "🏊", label: "Pool & Spa", sub: "Outdoor wellness" },
  { emoji: "🌿", label: "Nature areas", sub: "Gardens & trails" },
  { emoji: "🍽️", label: "Restaurant", sub: "Regional cuisine" },
  { emoji: "🎊", label: "Event halls", sub: "Up to 150 guests" },
];

const wetAreaPoints = [
  "Outdoor swimming pool",
  "Sauna & steam room",
  "Hydromassage jets",
  "Included with Full Day package",
];

const waText = `Hi, I'd like information about the facilities at ${SITE.name}.`;
const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout
  lang="en"
  title={`Facilities | ${SITE.name}`}
  description="Spaces designed for rest, enjoyment and reconnection at Hostería Agoyán."
>
  <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div
      class="relative h-[62vh] min-h-[480px] overflow-hidden rounded-b-[2.5rem] bg-slate-950"
    >
      <img
        src={heroImage}
        alt="Facilities at Hostería Agoyán"
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <!-- lateral gradient -->
      <div
        class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"
      >
      </div>
      <!-- bottom gradient -->
      <div
        class="absolute inset-x-0 bottom-0 h-56 bg-gradient-to-t from-black/60 to-transparent"
      >
      </div>

      <!-- breadcrumb -->
      <div
        class="absolute left-8 top-8 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-white/70"
      >
        <a href="/en/" class="transition hover:text-white">Home</a>
        <span class="text-white/40">/</span>
        <span class="text-white">Our Facilities</span>
      </div>

      <!-- main content -->
      <div class="absolute inset-0 flex items-center">
        <div class="w-full px-8 sm:px-12 lg:px-16">
          <div class="max-w-2xl">
            <p
              class="font-menu text-xs uppercase tracking-[0.2em] text-emerald-300"
            >
              HOSTERÍA AGOYÁN
            </p>
            <h1
              class="mt-3 font-hero text-5xl leading-[1.08] text-white sm:text-6xl lg:text-7xl"
            >
              Spaces designed<br />for every moment
            </h1>
            <p class="mt-5 max-w-xl text-base leading-7 text-white/80">
              Six unique facilities combining wellness, nature, gastronomy and
              entertainment — all in the heart of the Ecuadorian Andes.
            </p>

            <!-- WA button -->
            <div class="mt-8">
              <a
                href={waUrl}
                target="_blank"
                rel="noopener"
                class="hero-wa-btn inline-flex items-center gap-3 rounded-2xl px-7 py-3.5 text-sm font-semibold text-white"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 fill-white"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
                  ></path>
                </svg>
                Ask on WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- glassmorphism stats card -->
      <div class="absolute bottom-8 right-8 hidden lg:block">
        <div
          class="price-card rounded-[2rem] border border-white/20 p-6 shadow-[0_20px_50px_rgba(0,0,0,0.3)] backdrop-blur-xl"
        >
          <div class="grid grid-cols-2 gap-5">
            {
              heroStats.map((s) => (
                <div class="text-center">
                  <div class="text-2xl">{s.emoji}</div>
                  <div class="mt-1 text-sm font-bold text-white">{s.label}</div>
                  <div class="text-xs text-white/60">{s.sub}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- scroll arrow -->
      <div class="absolute bottom-7 left-1/2 hidden -translate-x-1/2 lg:block">
        <div class="scroll-arrow">
          <svg
            class="h-6 w-6 text-white/50"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ INTRO ═══════════════════════════════════════ -->
  <section class="bg-white py-16 sm:py-20">
    <div
      class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8"
      data-reveal
    >
      <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">
        AGOYÁN FACILITIES
      </p>
      <h2
        class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl lg:text-6xl"
      >
        Six spaces, one unforgettable experience
      </h2>
      <p
        class="mx-auto mt-5 max-w-3xl text-base leading-8 text-slate-600 sm:text-lg"
      >
        From the thermal pool to the event halls, every corner of Hostería
        Agoyán is designed to create memories — whether you're here for a day
        or a whole weekend.
      </p>

      <!-- stat grid -->
      <div class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-4" data-reveal>
        {
          [
            {
              emoji: "🏊",
              label: "Pool & Spa",
              sub: "Outdoor pool + wellness",
            },
            {
              emoji: "🌿",
              label: "Nature",
              sub: "Tropical gardens & trails",
            },
            { emoji: "🍽️", label: "Gastronomy", sub: "Regional & international" },
            { emoji: "🎊", label: "Events", sub: "Up to 150 guests" },
          ].map((s) => (
            <div class="rounded-2xl border border-slate-100 bg-slate-50 p-5 shadow-[0_4px_14px_rgba(0,0,0,0.04)]">
              <div class="text-3xl">{s.emoji}</div>
              <div class="mt-2 text-lg font-bold text-slate-900">{s.label}</div>
              <div class="mt-0.5 text-xs text-slate-500">{s.sub}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ FEATURED: WET AREA ═══════════════════════════════════════ -->
  <section class="bg-white pb-12 pt-0">
    <div class="w-full px-4 sm:px-6 lg:px-8" data-reveal>
      <div
        class="overflow-hidden rounded-[2.5rem] border border-slate-200 bg-slate-50 shadow-[0_20px_55px_rgba(0,0,0,0.08)]"
      >
        <div class="grid lg:grid-cols-[1.2fr_0.8fr]">
          <!-- image -->
          <div class="relative min-h-[380px] lg:min-h-[520px]">
            <img loading="eager" fetchpriority="high"
              src="/imagenes/instalaciones/FullDay2.jpg"
              alt="Wet Area — Hostería Agoyán"
              class="absolute inset-0 h-full w-full object-cover transition duration-700 hover:scale-[1.03]"
            />
            <div
              class="absolute inset-0 bg-gradient-to-r from-black/20 via-black/5 to-transparent"
            >
            </div>
            <div class="absolute left-6 top-6">
              <span
                class="rounded-full bg-emerald-500 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.1em] text-white shadow"
              >
                ⭐ Featured Space
              </span>
            </div>
          </div>

          <!-- text -->
          <div class="p-8 sm:p-10 lg:p-14">
            <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">
              WELLNESS
            </p>
            <h2
              class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl"
            >
              Wet Area
            </h2>
            <p class="mt-5 text-base leading-8 text-slate-600">
              The star of Hostería Agoyán. Pool, sauna, steam room and
              hydromassage combine for a complete wellness experience — ideal
              for couples, families and anyone looking to truly disconnect.
            </p>

            <ul class="mt-8 space-y-3">
              {
                wetAreaPoints.map((point) => (
                  <li class="flex items-center gap-3 text-slate-700">
                    <span class="inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100">
                      <svg
                        class="h-4 w-4 text-emerald-600"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2.5"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                    </span>
                    <span class="text-base">{point}</span>
                  </li>
                ))
              }
            </ul>

            <div class="mt-10 flex flex-col gap-4 sm:flex-row">
              <a
                href="/en/facilities/areaHumedaEN/"
                class="inline-flex items-center justify-center gap-2 rounded-2xl bg-emerald-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-emerald-400"
              >
                View wet area
                <svg
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
              <a
                href={waUrl}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50"
              >
                Ask on WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ ALL FACILITIES GRID ═══════════════════════════════════════ -->
  <section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-3xl text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">
          ALL FACILITIES
        </p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
          Every space designed to make your visit better
        </h2>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 xl:grid-cols-3">
        {
          facilities.map((item) => (
            <article
              class="group overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_12px_35px_rgba(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_22px_50px_rgba(0,0,0,0.11)]"
              data-reveal
            >
              <a href={item.href} class="block">
                <div class="relative h-72 overflow-hidden">
                  <img loading="lazy"
                    src={item.image}
                    alt={item.title}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform]"
                  />
                  <!-- emerald bar animation -->
                  <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-gradient-to-r from-emerald-400 to-teal-400 transition-transform duration-500 group-hover:scale-x-100 [will-change:transform]" />
                  <!-- gradient -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent" />
                  <!-- badge -->
                  <div class="absolute left-5 top-5">
                    <span class="rounded-full bg-white/95 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-slate-900 shadow">
                      {item.badge}
                    </span>
                  </div>
                  <!-- emoji -->
                  <div class="absolute right-5 top-5 text-2xl">{item.emoji}</div>
                </div>

                <div class="p-6">
                  <h3 class="font-menu text-2xl text-slate-900">{item.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-slate-600">
                    {item.description}
                  </p>

                  <!-- pills -->
                  <div class="mt-4 flex flex-wrap gap-2">
                    {item.pills.map((pill) => (
                      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">
                        {pill}
                      </span>
                    ))}
                  </div>

                  <!-- SVG arrow -->
                  <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition-all duration-200 group-hover:gap-3 group-hover:text-emerald-500">
                    <span>Explore space</span>
                    <svg
                      class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ DARK CTA ═══════════════════════════════════════ -->
  <section class="cta-section relative overflow-hidden py-28">
    <!-- grid pattern -->
    <div class="cta-grid pointer-events-none absolute inset-0"></div>

    <!-- glow orbs -->
    <div
      class="pointer-events-none absolute left-[12%] top-[20%] h-72 w-72 rounded-full bg-emerald-500/14 blur-[90px]"
    >
    </div>
    <div
      class="pointer-events-none absolute bottom-[15%] right-[10%] h-64 w-64 rounded-full bg-teal-400/11 blur-[80px]"
    >
    </div>
    <div
      class="pointer-events-none absolute right-[30%] top-[55%] h-48 w-48 rounded-full bg-emerald-600/10 blur-[70px]"
    >
    </div>

    <div
      class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8"
      data-reveal
    >
      <div
        class="cta-badge mx-auto mb-6 inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
        Open all year round
      </div>

      <h2
        class="font-hero text-5xl leading-[1.08] text-white sm:text-6xl lg:text-7xl"
      >
        Ready to explore<br />Hostería Agoyán?
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/70">
        From the pool to the event halls — every space is ready to make your
        visit unforgettable. Contact us directly for availability and bookings.
      </p>

      <!-- emoji pills -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {
          [
            "🏊 Wet Area",
            "🌿 Green Spaces",
            "🍽️ Restaurant",
            "🎱 Game Room",
            "🎊 Event Halls",
            "🎵 Disco",
          ].map((pill) => (
            <span class="rounded-full border border-white/15 bg-white/8 px-4 py-1.5 text-sm font-medium text-white/75">
              {pill}
            </span>
          ))
        }
      </div>

      <!-- WA button -->
      <div class="mt-10">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="cta-wa-btn inline-flex items-center gap-3 rounded-2xl bg-gradient-to-r from-emerald-500 to-teal-500 px-8 py-4 text-base font-bold text-white"
        >
          <svg
            viewBox="0 0 24 24"
            class="h-5 w-5 fill-white"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
            ></path>
          </svg>
          Contact us on WhatsApp
        </a>
      </div>

      <p class="mt-5 text-sm text-white/45">
        We reply quickly · No commitment required · Direct booking
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-wa-btn {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.38);
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      filter 0.22s ease;
  }
  .hero-wa-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.07);
    box-shadow: 0 14px 34px rgba(16, 185, 129, 0.48);
  }
  .price-card {
    background: rgba(255, 255, 255, 0.1);
  }
  .scroll-arrow {
    animation: bounce-arr 1.8s ease-in-out infinite;
  }
  @keyframes bounce-arr {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }
  .cta-section {
    background:
      radial-gradient(
        ellipse at 20% 50%,
        rgba(16, 185, 129, 0.18) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse at 80% 20%,
        rgba(20, 184, 166, 0.14) 0%,
        transparent 45%
      ),
      linear-gradient(
        160deg,
        #0d2218 0%,
        #0f2d22 30%,
        #0b2320 60%,
        #071a17 100%
      );
  }
  .cta-grid {
