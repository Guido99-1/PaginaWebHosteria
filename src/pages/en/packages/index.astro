---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";

const page = {
  title: "Our Packages",
  eyebrow: "AGOYÁN EXPERIENCES",
  subtitle:
    "From a full day of wellness to multi-day adventures across the region — discover packages designed for every kind of traveller at Hostería Agoyán in Baños de Agua Santa.",
  heroImage: "/imagenes/instalaciones/Aventura2.jpeg",
};

const mainPackages = [
  {
    title: "Full Day",
    description:
      "Enjoy a complete day at the inn with access to the pool, sauna, steam room, hydromassage and green areas — no overnight stay required.",
    price: "$10",
    priceNote: "per person",
    href: "/en/packages/full-day/",
    image: "/imagenes/instalaciones/FullDay.jpg",
    badge: "Day escape",
    pills: ["🏊 Pool", "♨️ Sauna", "🌿 Nature"],
  },
  {
    title: "Romantic Package",
    description:
      "A carefully crafted experience for couples — romantic room setup, wellness area access, wine and a private dinner for a night you'll never forget.",
    price: "$199",
    priceNote: "per couple",
    href: "/en/packages/romantic/",
    image: "/imagenes/instalaciones/Pareja2.jpg",
    badge: "For couples",
    pills: ["🍷 Wine & dinner", "🌸 Room setup", "♨️ Wellness"],
  },
  {
    title: "Family Stay",
    description:
      "A comfortable and welcoming retreat for families and groups — rooms, cabins, breakfast, pool and green spaces included in one relaxing package.",
    price: "$35 per person",
    priceNote: "per person / night",
    href: "/en/packages/lodging/",
    image: "/imagenes/instalaciones/Familia2.jpg",
    badge: "Families & groups",
    pills: ["🏡 Rooms & cabins", "🍳 Breakfast", "👶 Children u/5 free"],
  },
];

const adventurePackages = [
  {
    title: "Baños + Amazon",
    description:
      "Combine adventure and nature — explore the Route of the Waterfalls, the famous Casa del Árbol and a guided Amazon jungle experience.",
    price: "From $129",
    priceNote: "per person",
    href: "/en/packages/banos-amazon/",
    image: "/imagenes/instalaciones/Amazonia7.jpeg",
    badge: "Adventure",
    pills: ["🌊 Waterfalls", "🌳 Amazon", "🎒 Guided"],
  },
  {
    title: "Baños + Quilotoa",
    description:
      "Visit the mystical Quilotoa volcanic lagoon alongside the highlights of Baños — a journey through Ecuador's most breathtaking landscapes.",
    price: "From $135",
    priceNote: "per person",
    href: "/en/packages/banos-quilotoa/",
    image: "/imagenes/instalaciones/Quilotoa.jpeg",
    badge: "Cultural",
    pills: ["🌋 Quilotoa", "🗺️ 5 tours", "🎒 Guided"],
  },
  {
    title: "Baños Extreme",
    description:
      "Rafting, rappelling, zip-line and more — an action-packed package for thrill-seekers who want to push their limits in the heart of the Andes.",
    price: "From $155",
    priceNote: "per person",
    href: "/en/packages/banos-extreme/",
    image: "/imagenes/instalaciones/Extremo.jpeg",
    badge: "Extreme sports",
    pills: ["🚣 Rafting", "🧗 Rappelling", "⚡ Adrenaline"],
  },
  {
    title: "Baños Premium",
    description:
      "The ultimate Baños experience — 12+ activities, premium guided tours, exclusive access and everything you need for an unforgettable multi-day adventure.",
    price: "From $175",
    priceNote: "per person",
    href: "/en/packages/banos-premium/",
    image: "/imagenes/instalaciones/Aventura4.jpeg",
    badge: "Premium",
    pills: ["⭐ 12+ tours", "🎖️ Premium", "🏆 All inclusive"],
  },
];

const stats = [
  { value: "7",          label: "Packages",    icon: "📦" },
  { value: "All year",   label: "Availability", icon: "📅" },
  { value: "Direct",     label: "Booking",      icon: "💬" },
  { value: "WhatsApp",   label: "Support",      icon: "✅" },
];

const waText = `Hello, I'd like information about the packages at ${SITE.name}.`;
const waUrl  = `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout lang="en" title={`Packages | ${SITE.name}`} description={page.subtitle}>

  <!-- HERO -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative h-[62vh] min-h-[480px] overflow-hidden">
      <img src={page.heroImage} alt="Hostería Agoyán packages" class="absolute inset-0 h-full w-full object-cover object-center" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/35 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-black/10"></div>

      <div class="relative z-10 mx-auto flex h-full max-w-7xl items-end px-4 pb-14 pt-28 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-reveal>
          <div class="mb-4 flex items-center gap-2 font-menu text-xs tracking-[0.16em] text-white/55">
            <a href="/en/" class="transition hover:text-white/90">HOME</a>
            <span>/</span>
            <span class="text-emerald-300">{page.eyebrow}</span>
          </div>
          <h1 class="font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">{page.title}</h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-white/82 sm:text-lg">{page.subtitle}</p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href={waUrl} target="_blank" rel="noopener" class="hero-wa-btn inline-flex items-center justify-center gap-2.5 rounded-2xl px-7 py-3.5 text-sm font-bold text-white">
              <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
              Book via WhatsApp
            </a>
            <a href="#packages-list" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/30 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              View packages
            </a>
          </div>
        </div>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/45">
        <span class="font-menu text-[10px] tracking-widest">EXPLORE</span>
        <svg class="scroll-arrow" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </div>
    </div>
  </section>

  <!-- INTRO + STATS -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div data-reveal>
          <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">CHOOSE YOUR EXPERIENCE</p>
          <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Packages designed for every moment</h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            Whether you're looking for a romantic getaway, a relaxing full day, a comfortable family stay or an action-packed adventure through the Ecuadorian Andes, Hostería Agoyán has a package tailored exactly for you.
          </p>
          <p class="mt-4 text-base leading-8 text-slate-600">
            All packages include direct booking support via WhatsApp, personalized attention from our team and access to the most beautiful natural setting in Baños de Agua Santa.
          </p>
          <a href={waUrl} target="_blank" rel="noopener" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition hover:text-emerald-500">
            Ask us which package suits you best
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="rounded-[2rem] border border-slate-100 bg-slate-50 p-8 shadow-[0_16px_40px_rgba(0,0,0,0.05)]" data-reveal>
          <div class="grid grid-cols-2 gap-4">
            {stats.map((s) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_4px_16px_rgba(0,0,0,0.04)]">
                <div class="mb-2 text-2xl" aria-hidden="true">{s.icon}</div>
                <div class="font-hero text-2xl font-bold text-slate-900">{s.value}</div>
                <div class="mt-1 text-xs font-menu tracking-wider text-slate-500">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN PACKAGES -->
  <section id="packages-list" class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">INN EXPERIENCES</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Relax, connect and enjoy</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-slate-500">Packages centred on the inn's facilities — pool, wellness, nature and accommodation.</p>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        {mainPackages.map((item) => (
          <article class="group overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_12px_35px_rgba(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_22px_50px_rgba(0,0,0,0.11)]" data-reveal>
            <a href={item.href} class="block">
              <div class="relative h-72 overflow-hidden">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform]" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent"></div>
                <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-gradient-to-r from-emerald-400 to-teal-400 transition-transform duration-500 group-hover:scale-x-100 [will-change:transform]"></div>
                <div class="absolute left-4 top-4">
                  <span class="rounded-full bg-white/95 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-slate-800 shadow backdrop-blur">
                    {item.badge}
                  </span>
                </div>
                <div class="absolute bottom-4 left-4">
                  <div class="flex flex-col gap-0.5">
                    <span class="font-hero text-2xl font-bold text-white leading-none">{item.price}</span>
                    <span class="text-[11px] text-white/75">{item.priceNote}</span>
                  </div>
                </div>
              </div>
              <div class="p-6">
                <h3 class="font-hero text-xl text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {item.pills.map((pill) => (
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700 border border-emerald-100">{pill}</span>
                  ))}
                </div>
                <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition-colors group-hover:text-emerald-500">
                  View details
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ADVENTURE PACKAGES -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">BAÑOS ADVENTURES</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Explore beyond the inn</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-slate-500">Multi-day packages combining accommodation at Hostería Agoyán with guided tours throughout the Baños de Agua Santa region.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {adventurePackages.map((item) => (
          <article class="group overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_8px_28px_rgba(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_44px_rgba(0,0,0,0.10)]" data-reveal>
            <a href={item.href} class="block">
              <div class="relative h-52 overflow-hidden">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform]" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
                <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-gradient-to-r from-emerald-400 to-teal-400 transition-transform duration-500 group-hover:scale-x-100 [will-change:transform]"></div>
                <div class="absolute left-3 top-3">
                  <span class="rounded-full bg-white/92 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.07em] text-slate-800 shadow backdrop-blur">
                    {item.badge}
                  </span>
                </div>
                <div class="absolute bottom-3 left-3">
                  <span class="font-hero text-xl font-bold text-white leading-none">{item.price}</span>
                  <div class="text-[10px] text-white/70 mt-0.5">{item.priceNote}</div>
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-hero text-lg text-slate-900">{item.title}</h3>
                <p class="mt-2.5 text-xs leading-6 text-slate-600">{item.description}</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {item.pills.map((pill) => (
                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-medium text-emerald-700 border border-emerald-100">{pill}</span>
                  ))}
                </div>
                <div class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition-colors group-hover:text-emerald-500">
                  View details
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">WHY BOOK WITH US</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Everything in one place</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { icon: "📍", title: "Prime location",    desc: "In the heart of Baños de Agua Santa, with direct access to the most iconic destinations in Ecuador." },
          { icon: "🌿", title: "Nature & wellness", desc: "Pool, sauna, steam room, hydromassage and extensive green spaces — all within the inn's grounds." },
          { icon: "🎒", title: "Expert guides",     desc: "All adventure packages include experienced local guides for the safest and most immersive experience." },
          { icon: "💬", title: "Direct support",    desc: "Book directly via WhatsApp — no intermediaries, no hidden fees. Our team is available every day." },
        ].map((f) => (
          <div class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)]" data-reveal>
            <div class="mb-4 text-3xl" aria-hidden="true">{f.icon}</div>
            <h3 class="font-hero text-lg text-slate-900">{f.title}</h3>
            <p class="mt-2.5 text-sm leading-7 text-slate-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DARK CTA -->
  <section class="cta-section relative -mx-4 overflow-hidden py-28 sm:-mx-6 sm:py-36 lg:-mx-8">
    <div class="pointer-events-none absolute -left-32 -top-32 h-[480px] w-[480px] rounded-full bg-emerald-400/20 blur-[96px]"></div>
    <div class="pointer-events-none absolute -right-32 bottom-0 h-[440px] w-[440px] rounded-full bg-teal-300/15 blur-[80px]"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-emerald-500/10 blur-[100px]"></div>
    <div class="cta-grid pointer-events-none absolute inset-0 opacity-[0.06]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-300/40 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal-300/30 to-transparent"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <div class="mb-8 flex justify-center">
        <div class="cta-badge inline-flex h-16 w-16 items-center justify-center rounded-2xl">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
      </div>
      <p class="font-menu text-sm tracking-[0.2em] text-emerald-300">DIRECT BOOKING</p>
      <h2 class="mt-5 font-hero text-4xl leading-[1.04] text-white sm:text-5xl lg:text-6xl">Not sure which<br />package is right for you?</h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-white/75 sm:text-lg">
        Message us on WhatsApp and we'll help you find the perfect option based on your group, budget and the kind of experience you're looking for. We're here every day to make it easy.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        {[
          { icon: "🏊", label: "Wellness & pool" },
          { icon: "🎒", label: "Adventure tours" },
          { icon: "🌿", label: "Nature & relaxation" },
        ].map((f) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-5 py-2 text-sm text-white/85 backdrop-blur">
            <span aria-hidden="true">{f.icon}</span>{f.label}
          </span>
        ))}
      </div>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={waUrl} target="_blank" rel="noopener" class="cta-wa-btn inline-flex min-w-[220px] items-center justify-center gap-2.5 rounded-2xl bg-white px-8 py-4 text-sm font-bold text-emerald-700">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          Ask via WhatsApp
        </a>
        <a href="/en/" class="inline-flex min-w-[200px] items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-sm font-semibold text-white backdrop-blur transition hover:border-white/40 hover:bg-white/18">
          Back to home
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

