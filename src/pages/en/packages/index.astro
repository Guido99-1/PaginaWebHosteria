---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";

const page = {
  title: "Packages",
  subtitle:
    "Discover experiences designed for rest, connection and enjoyment at Hostería Agoyán.",
  heroImage: "/imagenes/packeges/wallpaper1.jpg",
};

const packages = [
  {
    title: "Full Day",
    description:
      "An ideal option to enjoy a full day at the inn with access to the pool, sauna, steam room and green areas.",
    price: "From $25",
    href: "/en/packages/full-day/",
    image: "/imagenes/packeges/full-day/pareja.jpg",
    badge: "Day escape",
  },
  {
    title: "Romantic Package",
    description:
      "A special experience for couples with romantic details, wellness area access and unforgettable moments.",
    price: "From $199",
    href: "/en/packages/romantic/",
    image: "/imagenes/packeges/romance/romance.jpg",
    badge: "For couples",
  },
  {
    title: "Lodging",
    description:
      "A comfortable and welcoming option for families or groups who want to relax and enjoy nature.",
    price: "From $85",
    href: "/en/packages/lodging/",
    image: "/imagenes/packeges/hospedaje/wallpaper2.jpg",
    badge: "Families & groups",
  },
];

const waText = `Hi, I'd like information about the packages at ${SITE.name}.`;
const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout
  lang="en"
  title={`Packages | ${SITE.name}`}
  description={page.subtitle}
>
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative min-h-[58vh] overflow-hidden">
      <img
        src={page.heroImage}
        alt="Hostería Agoyán packages"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950/75 via-slate-950/20 to-slate-950/10"></div>

      <div class="relative z-10 mx-auto flex min-h-[58vh] max-w-7xl items-end px-4 pb-14 pt-28 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-reveal>
          <p class="font-menu text-sm tracking-[0.14em] text-emerald-300">
            AGOYÁN EXPERIENCES
          </p>
          <h1 class="mt-4 font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">
            {page.title}
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-white/82 sm:text-lg">
            {page.subtitle}
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href={waUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center rounded-2xl bg-emerald-500 px-6 py-3.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-emerald-400"
            >
              Book on WhatsApp
            </a>

            <a
              href="#packages-list"
              class="inline-flex items-center justify-center rounded-2xl border border-white/30 bg-white/10 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18"
            >
              View packages
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1fr_1fr] lg:items-center">
        <div data-reveal>
          <p class="font-menu text-sm text-emerald-600">Choose your experience</p>
          <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
            Packages designed for different moments
          </h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            Whether you are looking for a romantic getaway, a relaxing day or a
            comfortable family stay, here you will find options designed to help
            you enjoy the best of Hostería Agoyán.
          </p>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-slate-50 p-8 shadow-[0_16px_40px_rgba(0,0,0,0.05)]" data-reveal>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl bg-white p-5 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
              <div class="text-sm text-slate-500">Options</div>
              <div class="mt-2 text-2xl font-bold text-slate-900">3 packages</div>
            </div>
            <div class="rounded-2xl bg-white p-5 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
              <div class="text-sm text-slate-500">Booking</div>
              <div class="mt-2 text-2xl font-bold text-slate-900">Direct</div>
            </div>
            <div class="rounded-2xl bg-white p-5 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
              <div class="text-sm text-slate-500">Availability</div>
              <div class="mt-2 text-2xl font-bold text-slate-900">All year</div>
            </div>
            <div class="rounded-2xl bg-white p-5 shadow-[0_8px_24px_rgba(0,0,0,0.04)]">
              <div class="text-sm text-slate-500">Support</div>
              <div class="mt-2 text-2xl font-bold text-slate-900">WhatsApp</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="packages-list" class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-12 max-w-3xl text-center" data-reveal>
        <p class="font-menu text-sm text-sky-600">Our packages</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
          Find the ideal option for your trip
        </h2>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        {packages.map((item) => (
          <article
            class="group overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_12px_35px_rgba(0,0,0,0.06)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(0,0,0,0.10)]"
            data-reveal
          >
            <a href={item.href} class="block">
              <div class="relative h-80 overflow-hidden">
                <img
                  src={item.image}
                  alt={item.title}
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/8 to-transparent"></div>

                <div class="absolute left-5 top-5">
                  <span class="rounded-full bg-white/95 px-4 py-2 text-xs font-semibold uppercase tracking-[0.08em] text-slate-900 shadow">
                    {item.badge}
                  </span>
                </div>

                <div class="absolute bottom-5 left-5">
                  <span class="rounded-full bg-emerald-500 px-4 py-2 text-sm font-semibold text-white shadow">
                    {item.price}
                  </span>
                </div>
              </div>

              <div class="p-6">
                <h3 class="font-menu text-2xl text-slate-900">{item.title}</h3>
                <p class="mt-4 text-sm leading-7 text-slate-600">
                  {item.description}
                </p>

                <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition group-hover:text-emerald-500">
                  <span>View details</span>
                  <span aria-hidden="true">→</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8" data-reveal>
      <div class="rounded-[2.2rem] border border-slate-200 bg-[linear-gradient(135deg,#f8fafc,#eefbf6)] p-8 text-center shadow-[0_18px_45px_rgba(0,0,0,0.06)] sm:p-12">
        <p class="font-menu text-sm text-emerald-600">Direct booking</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">
          Need help choosing?
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-slate-600">
          Message us on WhatsApp and we will help you find the ideal package
          based on your trip, your budget and the kind of experience you want.
        </p>

        <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
          <a
            href={waUrl}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-2xl bg-emerald-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-emerald-400"
          >
            Ask on WhatsApp
          </a>
          <a
            href="/en/contact/"
            class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-50"
          >
            Go to contact
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>