---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { SITE } from "../../../../config/site";

const pkg = {
  title: "Baños Extreme Package",
  eyebrow: "BAÑOS EXTREME",
  subtitle:
    "The ultimate adrenaline experience: rafting, rappelling, canyoning, and every iconic attraction in Baños. All private trail entries included — no hidden costs, just pure adventure.",
  price: "$155",
  priceNote: "per person",
  duration: "2 Nights / 3 Days",
  guests: "From 1 person",
  availability: "All year round",
  heroImage: "/imagenes/instalaciones/Extremo.jpeg",
  gallery: [
    { src: "/imagenes/instalaciones/Aventura.jpeg",        alt: "Waterfalls of Baños" },
    { src: "/imagenes/instalaciones/Aventura4.jpeg",        alt: "Extreme adventure in Baños" },
    { src: "/imagenes/instalaciones/Extremo3.jpg",  alt: "Nature and adventure" },
    { src: "/imagenes/instalaciones/Extremo.jpeg", alt: "Nature and adventure" },
  ],
  includes: [
    "2-night accommodation at Hostería Agoyán",
    "Breakfast included per night of stay",
    "Access to SPA area: Pool, Sauna, Steam Room, Jacuzzi, Bonfire, and Game Room",
    "Transportation by chiva or private vehicle to all tourist attractions",
    "Certified professional guide for each tour",
    "All private trail entry fees included",
    "Tree House Tour: Swing at the End of the World, Hummingbird Nest, and viewpoints",
    "Hands of God Tour: Duende House, Angel Wings, Fortune Mushroom, and free canelazo",
    "Animal Park Tour: exotic fauna and wildlife encounters",
    "Waterfalls Route Tour: Agoyán, Culebrilla, Esperanza, Puertas del Cielo, Manto de la Novia, and Pailón del Diablo",
    "Dragon Labyrinth Tour: spectacular natural rock formation",
    "Canyoning and Rappelling on Baños waterfalls",
    "Rafting on the Pastaza River — extreme included",
    "10% discount for children aged 5 to 11",
  ],
  extras: [
    "Additional extreme sports: Zipline, Giant Swing, Tibetan Bridge, Cable Car (extra cost)",
    "Additional attractions at Mira-Mera (extra cost)",
    "Single room upgrade (+$15)",
    "Upgrade to cabin or premium suite",
    "Amazon Rainforest Full Day (extra cost)",
  ],
  conditions: [
    "Check-in after midday (approx.)",
    "Remaining balance must be paid before boarding transportation",
    "Please arrive 10 minutes before departure time",
    "Children under 5 travel on parents' lap",
    "Extreme activities subject to weather and physical condition",
    "Tours subject to availability and changes without prior notice",
    "Tours are non-refundable and non-transferable",
  ],
};

const related = [
  { title: "Baños + Quilotoa Package", href: "/en/packages/banos-quilotoa/", image: "/imagenes/instalaciones/AreasVerdes2.jpeg" },
  { title: "Baños Premium Package",    href: "/en/packages/banos-premium/",  image: "/imagenes/instalaciones/ExteriorSuites2.jpg" },
];

const waText = `Hello, I'd like some information about booking the ${pkg.title} at ${SITE.name}.`;
const waUrl  = `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);
---

<BaseLayout lang="en" title={`${pkg.title} | ${SITE.name}`} description={pkg.subtitle}>

  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative h-[82vh] min-h-[600px] overflow-hidden">
      <img src={pkg.heroImage} alt={pkg.title} class="absolute inset-0 h-full w-full object-cover object-center" loading="eager" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/10"></div>

      <div class="relative z-10 mx-auto flex h-full max-w-7xl items-end px-4 pb-14 pt-28 sm:px-6 lg:px-8">
        <div class="grid w-full gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
          <div data-reveal>
            <div class="mb-4 flex items-center gap-2 font-menu text-xs tracking-[0.16em] text-white/55">
              <a href="/en/packages/" class="transition hover:text-white/90">PACKAGES</a>
              <span>/</span>
              <span class="text-emerald-300">{pkg.eyebrow}</span>
            </div>
            <h1 class="font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">{pkg.title}</h1>
            <p class="mt-5 max-w-2xl text-base leading-8 text-white/82 sm:text-lg">{pkg.subtitle}</p>
            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a href={waUrl} target="_blank" rel="noopener" class="hero-wa-btn inline-flex items-center justify-center gap-2.5 rounded-2xl px-7 py-3.5 text-sm font-bold text-white">
                <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
                Book via WhatsApp
              </a>
              <a href="#includes" class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/30 bg-white/10 px-7 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
                See what's included
              </a>
            </div>
          </div>

          <aside class="price-card rounded-[2rem] border border-white/20 p-6 text-white shadow-[0_24px_60px_rgba(0,0,0,0.3)] backdrop-blur-xl" data-reveal>
            <div class="font-menu text-xs tracking-[0.14em] text-white/60">REFERENCE PRICE</div>
            <div class="mt-3 font-hero text-6xl font-bold leading-none text-white">{pkg.price}</div>
            <div class="mt-1.5 text-sm text-white/65">{pkg.priceNote} · <span class="text-amber-300">$169 on holidays</span></div>
            <div class="mt-6 grid grid-cols-2 gap-2.5">
              {[
                { label: "Duration",     value: pkg.duration },
                { label: "Guests",       value: pkg.guests },
                { label: "Tickets",      value: "Included" },
                { label: "Children 5–11", value: "–10%" },
              ].map((d) => (
                <div class="rounded-2xl border border-white/10 bg-black/20 p-3.5">
                  <div class="text-[10px] font-menu tracking-wider text-white/55">{d.label}</div>
                  <div class="mt-1 text-sm font-semibold text-white">{d.value}</div>
                </div>
              ))}
            </div>
            <a href={waUrl} target="_blank" rel="noopener" class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-white px-5 py-3 text-sm font-bold text-emerald-700 transition hover:bg-emerald-50">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
              Check availability
            </a>
          </aside>
        </div>
      </div>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/45">
        <span class="font-menu text-[10px] tracking-widest">EXPLORE</span>
        <svg class="scroll-arrow" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
      </div>
    </div>
  </section>

  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div data-reveal>
          <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">MAXIMUM ADRENALINE IN BAÑOS</p>
          <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Rafting, rappelling, and every iconic tour in one package</h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            The Baños Extreme Package is designed for thrill-seekers who want to experience everything Baños de Agua Santa has to offer — without compromise. Rafting on the Pastaza River, rappelling and canyoning on waterfalls, and the most iconic tours: Tree House, Waterfalls Route, Animal Park, and Dragon Labyrinth.
          </p>
          <p class="mt-4 text-base leading-8 text-slate-600">
            All private trail entry fees are included, so there are no unexpected costs. Just three days of pure adventure with a professional guide at every step and private transportation to all attractions.
          </p>
          <a href={waUrl} target="_blank" rel="noopener" class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 transition hover:text-emerald-500">
            Check availability
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="relative pb-10" data-reveal>
          <img src="/imagenes/instalaciones/Extremo2.jpeg" alt="Baños Extreme" class="w-full rounded-[2rem] object-cover shadow-[0_20px_50px_rgba(0,0,0,0.10)]" loading="lazy" />
          <div class="absolute -bottom-2 left-6 max-w-[280px] rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-[0_16px_40px_rgba(0,0,0,0.10)]">
            <div class="flex items-center gap-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-emerald-100">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-600"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </span>
              <div class="text-sm font-semibold text-slate-900">All entries included</div>
            </div>
            <p class="mt-2 text-xs leading-6 text-slate-500">Rafting, rappelling, canyoning, and every private trail entry fee — no extras to pay.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="includes" class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">WHAT'S INCLUDED</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Everything included, nothing held back</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
        {pkg.includes.map((item) => (
          <div class="group flex items-start gap-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-[0_4px_16px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_12px_28px_rgba(0,0,0,0.08)]" data-reveal>
            <span class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 transition-colors duration-300 group-hover:bg-emerald-200">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-600"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
            <p class="text-sm leading-7 text-slate-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-14 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">GALLERY</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Adventure at every turn</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <div class="group relative overflow-hidden rounded-3xl lg:col-span-2 lg:row-span-2" data-reveal>
          <img src={pkg.gallery[0].src} alt={pkg.gallery[0].alt} class="h-[280px] w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform] lg:h-full lg:min-h-[460px]" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          <span class="absolute bottom-4 left-4 rounded-full bg-white/90 px-3.5 py-1.5 text-xs font-semibold text-slate-800 opacity-0 backdrop-blur transition-opacity duration-300 group-hover:opacity-100">{pkg.gallery[0].alt}</span>
        </div>
        {pkg.gallery.slice(1).map((img) => (
          <div class="group relative overflow-hidden rounded-3xl" data-reveal>
            <img src={img.src} alt={img.alt} class="h-[210px] w-full object-cover transition-transform duration-700 group-hover:scale-105 [will-change:transform]" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
            <span class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-slate-800 opacity-0 backdrop-blur transition-opacity duration-300 group-hover:opacity-100">{img.alt}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_8px_28px_rgba(0,0,0,0.05)]" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">EXTRAS</p>
        <h3 class="mt-3 font-hero text-3xl text-slate-900">Optional services</h3>
        <ul class="mt-6 space-y-4">
          {pkg.extras.map((item) => (
            <li class="flex items-start gap-3.5">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-teal-100"><svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" class="text-teal-600"><path d="M12 5v14M5 12h14"/></svg></span>
              <span class="text-sm leading-7 text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_8px_28px_rgba(0,0,0,0.05)]" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-slate-500">CONDITIONS</p>
        <h3 class="mt-3 font-hero text-3xl text-slate-900">Before booking</h3>
        <ul class="mt-6 space-y-4">
          {pkg.conditions.map((item) => (
            <li class="flex items-start gap-3.5">
              <span class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-slate-100"><svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-500"><path d="M12 8v4M12 16h.01"/><circle cx="12" cy="12" r="10"/></svg></span>
              <span class="text-sm leading-7 text-slate-600">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="cta-section relative -mx-4 overflow-hidden py-28 sm:-mx-6 sm:py-36 lg:-mx-8">
    <div class="pointer-events-none absolute -left-32 -top-32 h-[480px] w-[480px] rounded-full bg-emerald-400/20 blur-[96px]"></div>
    <div class="pointer-events-none absolute -right-32 bottom-0 h-[440px] w-[440px] rounded-full bg-teal-300/15 blur-[80px]"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[560px] w-[560px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-emerald-500/10 blur-[100px]"></div>
    <div class="cta-grid pointer-events-none absolute inset-0 opacity-[0.06]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-300/40 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal-300/30 to-transparent"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <div class="mb-8 flex justify-center">
        <div class="cta-badge inline-flex h-16 w-16 items-center justify-center rounded-2xl">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
      </div>
      <p class="font-menu text-sm tracking-[0.2em] text-emerald-300">BOOK YOUR BAÑOS EXTREME PACKAGE</p>
      <h2 class="mt-5 font-hero text-4xl leading-[1.04] text-white sm:text-5xl lg:text-6xl">Rafting, rappelling,<br />and pure adrenaline</h2>
      <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-white/75 sm:text-lg">
        The most complete extreme adventure package in Baños de Agua Santa. All entries included, all the iconic tours, and the most thrilling activities — with a professional guide and no surprises on the bill.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        {[
          { icon: "🏄", label: "Rafting included" },
          { icon: "🧗", label: "Rappelling on waterfalls" },
          { icon: "🎫", label: "All private entries" },
        ].map((f) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-5 py-2 text-sm text-white/85 backdrop-blur">
            <span aria-hidden="true">{f.icon}</span>{f.label}
          </span>
        ))}
      </div>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={waUrl} target="_blank" rel="noopener" class="cta-wa-btn inline-flex min-w-[220px] items-center justify-center gap-2.5 rounded-2xl bg-white px-8 py-4 text-sm font-bold text-emerald-700">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
          Book via WhatsApp
        </a>
        <a href="/en/packages/" class="inline-flex min-w-[200px] items-center justify-center rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-sm font-semibold text-white backdrop-blur transition hover:border-white/40 hover:bg-white/18">
          View all packages
        </a>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.16em] text-emerald-600">YOU MIGHT ALSO BE INTERESTED IN</p>
        <h2 class="mt-3 font-hero text-4xl text-slate-900 sm:text-5xl">Other packages</h2>
