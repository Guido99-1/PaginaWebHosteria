---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE } from "../../../config/site";

const content = {
  eyebrow: "CONTACT & LOCATION",
  title: "We're ready to help you plan your next visit",
  subtitle:
    "Write to us for inquiries, reservations or information about our facilities, packages and promotions at Hostería Agoyán.",
  phoneLabel: "Phone",
  emailLabel: "Email",
  addressLabel: "Address",
  scheduleLabel: "Hours",
  scheduleText: "Open every day",
  whatsappButton: "Chat on WhatsApp",
  mapTitle: "Our location",
};

const waText = `Hi, I'd like information to book at ${SITE.name}.`;
const waUrl =
  `https://wa.me/${SITE.whatsappNumber}?text=` + encodeURIComponent(waText);

const displayPhone =
  SITE.phone && String(SITE.phone).trim().length > 0
    ? String(SITE.phone)
    : `+${SITE.whatsappNumber}`;

const mapEmbedUrl =
  SITE.googleMapsEmbedUrl ||
  "https://www.google.com/maps?q=Hoster%C3%ADa%20Agoyan%20Deluxe&z=16&output=embed";

const directionsUrl = SITE.googleMapsDirectionsUrl || SITE.googleMapsEmbedUrl || "#";

const faqs = [
  {
    q: "Do I need to book in advance?",
    a: "Yes, we recommend booking at least 2 days in advance, especially on weekends and holidays. Write to us on WhatsApp to check availability instantly.",
  },
  {
    q: "What's included in the lodging package?",
    a: "Lodging includes accommodation, access to the pool, sauna and steam room, and breakfast. Exact details vary depending on the package selected.",
  },
  {
    q: "Do you accept walk-ins (pool / day trip only)?",
    a: "Yes, we offer access to the recreational area for the day. We recommend confirming availability before coming, especially on weekends.",
  },
  {
    q: "How do I get there from downtown Baños de Agua Santa?",
    a: "We're located just a few minutes from the center of Baños de Agua Santa. You can arrive by taxi, private vehicle or public transport. Use the 'Get Directions' button to see the exact route on Google Maps.",
  },
  {
    q: "Do you accept pets?",
    a: "Yes! Furry friends are welcome at Hostería Agoyán. An additional fee of $10 per visit applies. If you have any special requests or need more information, don't hesitate to contact us — we'll be happy to help!",
  },
  {
    q: "What are your hours?",
    a: "We're open every day. You can write to us on WhatsApp at any time and we'll get back to you as soon as possible.",
  },
];
---

<BaseLayout
  lang="en"
  title={`Contact | ${SITE.name}`}
  description="Get in touch with Hostería Agoyán for reservations, inquiries and directions."
>
  <!-- Hero -->
  <section class="relative -mx-4 sm:-mx-6 lg:-mx-8">
    <div class="relative min-h-[58vh] overflow-hidden">
      <img loading="eager" fetchpriority="high"
        src="/imagenes/instalaciones/ExteriorComedor.jpg"
        alt="Contact Hostería Agoyán"
        class="absolute inset-0 h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-black/18 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/28 via-transparent to-transparent"></div>

      <div class="relative z-10 mx-auto flex min-h-[58vh] max-w-7xl items-end px-4 pb-14 pt-28 sm:px-6 lg:px-8">
        <div class="max-w-3xl" data-reveal>
          <p class="font-menu text-sm tracking-[0.14em] text-emerald-300">
            {content.eyebrow}
          </p>
          <h1 class="mt-4 font-hero text-5xl leading-[1.02] text-white sm:text-6xl lg:text-7xl">
            Contact
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-8 text-white/82 sm:text-lg">
            {content.subtitle}
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href={waUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center rounded-2xl bg-emerald-500 px-6 py-3.5 text-sm font-semibold text-white shadow-[0_16px_34px_rgba(16,185,129,0.24)] transition hover:-translate-y-0.5 hover:bg-emerald-400"
            >
              {content.whatsappButton}
            </a>

            <a
              href="#contact-info"
              class="inline-flex items-center justify-center rounded-2xl border border-white/30 bg-white/10 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/18"
            >
              View information
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">
        {content.eyebrow}
      </p>
      <h2 class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl lg:text-6xl">
        {content.title}
      </h2>
      <p class="mx-auto mt-5 max-w-3xl text-base leading-8 text-slate-600 sm:text-lg">
        Whether for lodging, promotions, packages or general information,
        we'll be delighted to help you.
      </p>
    </div>
  </section>

  <!-- Contact + Map -->
  <section id="contact-info" class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <!-- Left -->
        <div class="space-y-6" data-reveal>
          <div class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-[0_12px_35px_rgba(0,0,0,0.05)]">
            <p class="font-menu text-sm tracking-[0.14em] text-sky-600">
              CONTACT INFORMATION
            </p>
            <h3 class="mt-3 font-hero text-3xl text-slate-900 sm:text-4xl">
              Book and inquire directly
            </h3>
            <p class="mt-4 text-base leading-8 text-slate-600">
              You can write to us or call us to check availability,
              promotions, packages or information about our facilities.
            </p>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(0,0,0,0.04)] transition hover:-translate-y-0.5 hover:shadow-[0_16px_34px_rgba(0,0,0,0.07)]">
              <p class="text-sm font-semibold text-slate-900">{content.phoneLabel}</p>
              <a
                href={`tel:${displayPhone.replace(/\s+/g, "")}`}
                class="mt-3 block text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl"
              >
                {displayPhone}
              </a>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Quick response for bookings and inquiries.
              </p>
            </div>

            <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(0,0,0,0.04)] transition hover:-translate-y-0.5 hover:shadow-[0_16px_34px_rgba(0,0,0,0.07)]">
              <p class="text-sm font-semibold text-slate-900">{content.scheduleLabel}</p>
              <p class="mt-3 text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">
                Every day
              </p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                {content.scheduleText}
              </p>
            </div>
          </div>

          <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(0,0,0,0.04)]">
            <p class="text-sm font-semibold text-slate-900">{content.emailLabel}</p>
            <a
              href={`mailto:${SITE.email}`}
              class="mt-2 block text-base font-medium text-slate-700 transition hover:text-emerald-600"
            >
              {SITE.email}
            </a>
          </div>

          <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(0,0,0,0.04)]">
            <p class="text-sm font-semibold text-slate-900">{content.addressLabel}</p>
            <p class="mt-2 text-base text-slate-700">
              {SITE.address || "Baños de Agua Santa, Ecuador"}
            </p>
          </div>

          <!-- Social media -->
          <div class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-[0_10px_28px_rgba(0,0,0,0.04)]">
            <p class="text-sm font-semibold text-slate-900">Follow us</p>
            <div class="mt-4 flex flex-wrap gap-3">
              {SITE.socials.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:-translate-y-0.5 hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700"
                >
                  {s.label === "Instagram" && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                      <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.7"/>
                      <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.7"/>
                      <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                    </svg>
                  )}
                  {s.label === "Facebook" && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                    </svg>
                  )}
                  {s.label === "TikTok" && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                      <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                  {s.label}
                </a>
              ))}
            </div>
          </div>

          <div class="flex flex-col gap-4 sm:flex-row">
            <a
              href={waUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-2xl bg-emerald-500 px-6 py-3.5 text-sm font-semibold text-white shadow-[0_14px_30px_rgba(16,185,129,0.22)] transition hover:bg-emerald-400"
            >
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              {content.whatsappButton}
            </a>

            <a
              href={directionsUrl}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 rounded-2xl border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-900 transition hover:bg-slate-100"
            >
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/>
              </svg>
              Get Directions
            </a>
          </div>
        </div>

        <!-- Right: Map -->
        <div data-reveal>
          <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_18px_45px_rgba(0,0,0,0.08)]">
            <div class="border-b border-slate-200 px-6 py-5">
              <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">
                {content.mapTitle}
              </p>
              <h3 class="mt-2 font-hero text-2xl text-slate-900 sm:text-3xl">
                Find us in Baños de Agua Santa
              </h3>
            </div>

            <div class="relative h-[420px] w-full bg-slate-100">
              <iframe
                src={mapEmbedUrl}
                class="absolute inset-0 h-full w-full"
                style="border:0;"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                title="Hostería Agoyán Map"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:items-start">
        <!-- Left text -->
        <div data-reveal>
          <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">SEND US A MESSAGE</p>
          <h2 class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl">
            Got a question?
          </h2>
          <p class="mt-5 text-base leading-8 text-slate-600">
            Fill out the form and we'll get back to you shortly. You can also
            write to us directly on WhatsApp if you prefer immediate attention.
          </p>

          <ul class="mt-8 space-y-4">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-sm leading-6 text-slate-600">Availability and pricing inquiries</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-sm leading-6 text-slate-600">Information about packages and promotions</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-sm leading-6 text-slate-600">Private events and group bookings</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span class="text-sm leading-6 text-slate-600">Any other question or comment</span>
            </li>
          </ul>
        </div>

        <!-- Right: Form -->
        <div data-reveal>
          <div class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-[0_18px_45px_rgba(0,0,0,0.06)] sm:p-9">
            <!-- Replace the action with your Formspree ID: https://formspree.io -->
            <form
              action="https://formspree.io/f/YOUR_FORM_ID"
              method="POST"
              class="space-y-5"
              id="contact-form-en"
            >
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="nombre" class="mb-1.5 block text-sm font-semibold text-slate-700">
                    Name
                  </label>
                  <input
                    id="nombre"
                    name="nombre"
                    type="text"
                    required
                    placeholder="Your name"
                    class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-emerald-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-200 transition"
                  />
                </div>
                <div>
                  <label for="whatsapp" class="mb-1.5 block text-sm font-semibold text-slate-700">
                    WhatsApp or email
                  </label>
                  <input
                    id="whatsapp"
                    name="contacto"
                    type="text"
                    required
                    placeholder="Your number or email"
                    class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-emerald-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-200 transition"
                  />
                </div>
              </div>

              <div>
                <label for="asunto" class="mb-1.5 block text-sm font-semibold text-slate-700">
                  Subject
                </label>
                <select
                  id="asunto"
                  name="asunto"
                  class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 focus:border-emerald-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-200 transition"
                >
                  <option value="">Select a topic</option>
                  <option value="booking">Booking / Availability</option>
                  <option value="packages">Package information</option>
                  <option value="promotions">Promotions</option>
                  <option value="event">Private event / Group</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label for="mensaje" class="mb-1.5 block text-sm font-semibold text-slate-700">
                  Message
                </label>
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="4"
                  required
                  placeholder="How can we help you?"
                  class="w-full resize-none rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-emerald-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-200 transition"
                ></textarea>
              </div>

              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <p class="text-xs leading-5 text-slate-400">
                  You can also write to us directly on{" "}
                  <a href={waUrl} target="_blank" rel="noopener" class="font-medium text-emerald-600 hover:underline">
                    WhatsApp
                  </a>.
                </p>
                <button
                  type="submit"
                  class="form-submit inline-flex shrink-0 items-center justify-center rounded-2xl px-7 py-3.5 text-sm font-semibold text-white transition"
                >
                  Send message
                </button>
              </div>

              <!-- Success message (hidden by default) -->
              <div id="form-success-en" class="hidden rounded-xl bg-emerald-50 border border-emerald-200 px-5 py-4 text-sm text-emerald-700">
                Thank you for your message! We'll get back to you shortly.
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-slate-50 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center" data-reveal>
        <p class="font-menu text-sm tracking-[0.14em] text-emerald-600">FREQUENTLY ASKED QUESTIONS</p>
        <h2 class="mt-4 font-hero text-4xl leading-tight text-slate-900 sm:text-5xl">
          Everything you need to know
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-slate-600">
          We answer the most common questions. If you have a different inquiry, write to us directly.
        </p>
      </div>

      <div class="mt-12 space-y-3" data-reveal>
        {faqs.map((faq) => (
          <details class="faq-item group rounded-[1.5rem] border border-slate-200 bg-white shadow-[0_6px_20px_rgba(0,0,0,0.04)]">
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-7 py-5 text-base font-semibold text-slate-900 marker:content-none">
              {faq.q}
              <span class="faq-icon flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-slate-500 transition group-open:border-emerald-300 group-open:bg-emerald-50 group-open:text-emerald-600">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            <div class="px-7 pb-6 pt-0 text-sm leading-7 text-slate-600">
              {faq.a}
            </div>
          </details>
        ))}
      </div>

      <div class="mt-10 text-center" data-reveal>
        <p class="text-sm text-slate-500">
          Have another question?{" "}
          <a href={waUrl} target="_blank" rel="noopener" class="font-semibold text-emerald-600 hover:underline">
            Write to us on WhatsApp
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Extra CTA — full width, gradient background -->
  <section class="bg-gradient-to-br from-emerald-600 via-emerald-700 to-teal-800 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8" data-reveal>
      <!-- Icon -->
      <div class="mb-6 flex justify-center">
        <div class="inline-flex h-14 w-14 items-center justify-center rounded-full border border-white/20 bg-white/15 text-white backdrop-blur">
          <svg viewBox="0 0 24 24" width="26" height="26" fill="none" aria-hidden="true">
            <path d="M3 11l19-9-9 19-2-8-8-2Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

