---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSlider from "../../components/HeroSlider.astro";
import FeaturedPackages from "../../components/feacturePackages.astro";
import FeaturedPromotions from "../../components/FeaturedPromotions.astro";
import FacilitiesServices from "../../components/FacilitiesServices.astro";
import ContactSection from "../../components/ContactSection.astro";
import Testimonials from "../../components/Testimonials.astro";
import FinalCTA from "../../components/FinalCTA.astro";

const slides = [
  {
    title: "Nature, rest and comfort",
    subtitle: "Stay in Baños de Agua Santa with pool, sauna, steam room and green areas.",
    image: "/public/wallpaper1.jpg",
    ctaText: "View packages",
    ctaHref: "/en/packages/",
  },
  {
    title: "Unforgettable moments",
    subtitle: "A cozy atmosphere, beautiful views and experiences to disconnect.",
    image: "/public/wallpaper2.jpg",
    ctaText: "Contact us",
    ctaHref: "/en/contact/",
  },
];

const featuredPackages = [
  {
    title: "Full Day",
    price: "From $25",
    description: "Enjoy a special day with access to recreational areas, relaxation and nature.",
    image: "/public/fullday.jpg",
    href: "/en/packages/full-day/",
  },
  {
    title: "Romantic Package",
    price: "From $60",
    description: "Perfect for couples seeking privacy, comfort and an unforgettable experience.",
    image: "/public/romance.jpg",
    href: "/en/packages/romantic/",
  },
  {
    title: "Family Stay",
    price: "From $85",
    description: "A comfortable option for families with access to the inn’s spaces and services.",
    image: "/public/familia.jpg",
    href: "/en/packages/lodging/",
  },
];
const featuredPromotions = [
  {
    title: "Escapada Romántica",
    price: "Desde $70",
    description: "Una experiencia ideal para parejas con comodidad, privacidad y un ambiente especial para compartir.",
    image: "/public/fullday.jpg",
    href: "/es/promociones/escapada-romantica/",
    featured: true,
  },
  {
    title: "Promoción Full Day",
    price: "Desde $25",
    description: "Disfruta de un día de descanso con acceso a espacios recreativos y áreas de relajación.",
    image: "/public/familia.jpg",
    href: "/es/promociones/full-day/",
  },
  {
    title: "Fin de Semana Especial",
    price: "Desde $95",
    description: "Aprovecha una promoción perfecta para desconectarte y vivir una experiencia completa en la hostería.",
    image: "/images/promo-3.webp",
    href: "/es/promociones/fin-de-semana/",
  },
];
const facilitiesServices = [
  {
    title: "Parking Area",
    description: "We offer a safe and spacious parking area for the comfort of our guests.",
    icon: `
      <svg viewBox="0 0 24 24">
        <path d="M3 14l2-6a2 2 0 0 1 2-1h10a2 2 0 0 1 2 1l2 6" />
        <path d="M5 14h14v4a1 1 0 0 1-1 1h-1v-2H7v2H6a1 1 0 0 1-1-1v-4Z" />
