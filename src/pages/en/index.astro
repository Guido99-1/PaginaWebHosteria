    icon: `
      <svg viewBox="0 0 24 24">
        <rect x="4" y="5" width="16" height="15" rx="2" />
        <path d="M8 3v4M16 3v4M4 10h16" />
      </svg>
    `,
    href: "/en/services/events/",
  },
];
const testimonials = [
  {
    name: "Maria C.",
    comment:
      "A beautiful and peaceful place, perfect for relaxing. The service was kind and the facilities were clean and comfortable.",
    rating: 5,
    source: "Google",
    date: "2 weeks ago",
  },
  {
    name: "Carlos P.",
    comment:
      "The experience was excellent. The atmosphere, the view and the comfort made our stay truly enjoyable.",
    rating: 5,
    source: "Google",
    date: "1 month ago",
  },
  {
    name: "Andrea R.",
    comment:
      "Highly recommended for couples or families. We really liked the service and the relaxing environment.",
    rating: 5,
    source: "Google",
    date: "3 weeks ago",
  },
