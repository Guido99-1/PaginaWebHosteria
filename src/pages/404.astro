---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config/site";

const waUrl = `https://wa.me/${SITE.whatsappNumber}?text=` +
  encodeURIComponent("Hola, necesito ayuda para encontrar información en la web de Hostería Agoyán.");

const links = [
  { href: "/es/",                   label: "Inicio",        icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
  { href: "/es/paquetes/",          label: "Paquetes",      icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
  { href: "/es/instalaciones/",     label: "Instalaciones", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
  { href: "/es/promociones/",       label: "Promociones",   icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" },
  { href: "/es/contacto/",          label: "Contacto",      icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
];
---

<BaseLayout
  lang="es"
  title={`Página no encontrada | ${SITE.name}`}
  description="La página que buscas no existe. Encuentra paquetes, instalaciones y más en Hostería Agoyán."
>
  <section class="relative -mx-4 min-h-[90vh] overflow-hidden sm:-mx-6 lg:-mx-8">

    <!-- Fondo con gradiente oscuro similar al CTA -->
    <div class="absolute inset-0 bg-404"></div>

    <!-- Orbes de luz -->
    <div class="pointer-events-none absolute -left-32 top-20 h-[420px] w-[420px] rounded-full bg-emerald-400/20 blur-[90px]"></div>
    <div class="pointer-events-none absolute -right-24 bottom-10 h-[380px] w-[380px] rounded-full bg-teal-300/15 blur-[80px]"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/3 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-emerald-500/10 blur-[100px]"></div>

    <!-- Grid de puntos sutil -->
    <div class="dot-grid pointer-events-none absolute inset-0 opacity-[0.07]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-300/40 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-teal-300/30 to-transparent"></div>

    <!-- Contenido -->
    <div class="relative z-10 mx-auto flex min-h-[90vh] max-w-5xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8">

      <!-- Badge 404 -->
      <div class="badge-404 mb-6 inline-flex items-center gap-2 rounded-full px-5 py-2" data-reveal>
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        <span class="font-menu text-xs tracking-[0.22em] text-emerald-300">ERROR 404</span>
      </div>

      <!-- Número grande -->
      <div class="relative mb-4" data-reveal>
        <span class="number-404 select-none font-hero text-[clamp(8rem,22vw,16rem)] font-bold leading-none text-white/5">
          404
        </span>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <p class="font-menu text-sm tracking-[0.18em] text-emerald-400">PÁGINA NO ENCONTRADA</p>
            <h1 class="mt-2 font-hero text-3xl leading-snug text-white sm:text-4xl lg:text-5xl">
              ¡Ups! Esta ruta<br class="hidden sm:block" /> no existe
            </h1>
          </div>
        </div>
      </div>

      <!-- Descripción -->
      <p class="mt-2 max-w-xl text-base leading-8 text-white/65 sm:text-lg" data-reveal>
        La página que buscas no existe o fue movida. Puedes volver al inicio
        o explorar nuestros paquetes y servicios desde aquí.
      </p>

      <!-- Botones principales -->
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row" data-reveal>
        <a
          href="/es/"
          class="btn-primary inline-flex min-w-[200px] items-center justify-center gap-2.5 rounded-2xl px-8 py-4 text-sm font-bold text-white"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Ir al inicio
        </a>
        <a
          href={waUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex min-w-[200px] items-center justify-center gap-2.5 rounded-2xl border border-white/25 bg-white/10 px-8 py-4 text-sm font-semibold text-white backdrop-blur transition hover:border-white/40 hover:bg-white/18"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
          </svg>
          Ayuda por WhatsApp
        </a>
      </div>

      <!-- Divisor -->
      <div class="mt-16 w-full max-w-2xl border-t border-white/10" data-reveal></div>

      <!-- Links rápidos -->
      <div class="mt-10 w-full max-w-2xl" data-reveal>
        <p class="mb-6 font-menu text-xs tracking-[0.2em] text-white/45">O VISITA UNA DE ESTAS SECCIONES</p>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-5">
          {links.map((link) => (
            <a
              href={link.href}
              class="link-card group flex flex-col items-center gap-2 rounded-2xl border border-white/10 bg-white/5 px-3 py-4 text-center backdrop-blur transition-all duration-300 hover:border-emerald-400/40 hover:bg-white/10"
            >
              <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-500/15 text-emerald-300 transition-colors duration-300 group-hover:bg-emerald-500/25">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d={link.icon}/>
                </svg>
              </span>
              <span class="text-xs font-semibold text-white/70 transition-colors group-hover:text-white">{link.label}</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .bg-404 {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(16,185,129,0.18) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(20,184,166,0.14) 0%, transparent 45%),
      linear-gradient(160deg, #0d2218 0%, #0f2d22 30%, #0b2320 60%, #071a17 100%);
  }
  .dot-grid {
    background-image:
      linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }
  .badge-404 {
    background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(20,184,166,0.12));
    border: 1px solid rgba(16,185,129,0.28);
    box-shadow: 0 0 0 5px rgba(16,185,129,0.05);
  }
  .number-404 {
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    letter-spacing: -0.04em;
  }
  .btn-primary {
    background: linear-gradient(135deg, #10b981, #059669);
    box-shadow: 0 8px 28px rgba(16,185,129,0.38);
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    filter: brightness(1.07);
    box-shadow: 0 14px 36px rgba(16,185,129,0.50);
  }
</style>
